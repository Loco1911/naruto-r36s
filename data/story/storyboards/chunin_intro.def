[SceneDef]
font0 = font/Open_Sans.def
font0.height = 28
; teclas (según docs)
key.skip = s
key.cancel = a&b&c&x&y&z&m

stopmusic = 1

[Scene 0]
; bgm opcional
bgm = data/story/prologo/01.ogg
bgm.volume = 80

; texto 1
layer0.type = text
layer0.text = "Aldea Oculta de la Hoja...\nExamen Chunin."
layer0.font = 0,0,0,245,245,245
layer0.font.scale = 1.0, 1.0
layer0.textwindow = 20, 20, 300, 220
layer0.starttime = 0
layer0.endtime = 300
