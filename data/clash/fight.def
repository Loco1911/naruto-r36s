; Definition of fight screen
;-----------------------------------------
;----- Naruto Lifebar by Misterr07 -------
;-----------------------------------------

;-----------------------------------------------------------
;Directories are checked in this order:
;1. current directory fight.def is in
;2. data/
;3. your MUGEN directory

[Files]
sff = fight.sff
snd = fight.snd
font1 = jg.fnt
font2 = num1.fnt
font3 = name1.fnt
font4 = data/font/round.fnt
font5 = data/font/hits.fnt
font6 = data/font/timer.fnt 
font7 = data/font/winner.fnt 
font8 = data/font/draw.fnt 
font9 = data/font/names.fnt 

fightfx.sff = fightfx.sff
fightfx.air = fightfx.air
common.snd = common.snd

