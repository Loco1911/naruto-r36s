;-------------------------------------------------------------------------------------------------------
[Combo]
pos = 60,80         ;Coords to show
start.x = -40       ;Starting x-coords
counter.font = 3,0
counter.shake = 1   ;Set to 1 to shake count on hit
text.text = a	   ;You can use %i to show count in the text, eg "%i Hit!"
text.font = 3,0
text.offset = 30,0   ;Offset of text
displaytime = 90    ;Time to show text

;-------------------------------------------------------------------------------------------------------
[Round]
match.wins = 2               ;Rounds needed to win a match
match.maxdrawgames = 1       ;Max number of drawgames allowed (-1 for infinite) *2001.11.01 NEW*
start.waittime = 30          ;Time to wait before starting intro
pos = 0,0

round.time = 0               ;Time to show round display
round.default.offset = 160, 120
round.default.anim = 590
round.default.scale = 0.5,0.5
round.default.layerno = 1
round.default.displaytime = 80

; ROUND X
round1.snd = 0,1
round2.snd = 0,1
round3.snd = 0,1
round4.snd = 0,1
round5.snd = 0,1
round.sndtime = 0            ;Time to play the sounds

round1.offset = 160,120
round1.anim = 600
round1.scale =  0.5,0.5
round2.offset = 160,120
round2.anim = 610
round2.scale =  0.5,0.5
round3.offset = 160,120
round3.anim = 620
round3.scale =  0.5,0.5
round4.offset = 160,120
round4.anim = 630
round4.scale =  0.5,0.5
round5.offset = 160,120
round5.anim = 640
round5.scale = 0.5,0.5

; FIGHT
fight.time = 20              ;Time to show FIGHT component
fight.offset = 160,120       ;Component for FIGHT display
fight.anim = 168             ;.
fight.scale = 0.5,0.5
fight.snd = 1,0              ;Sound to play
fight.sndtime = 30           ;Time to play sound

ctrl.time = 80               ;Time players get control after "Fight"

; KO
KO.time    = 30              ;Time to show KO component
KO.offset  = 160,120         ;Component for KO display
KO.anim    = 169             ;.
KO.scale = 0.5,0.5
KO.snd     = 2,0             ;Sound to play for KO announcement
Ko.sndtime = 22 

; Double KO
DKO.offset = 160,120
DKO.anim = 170
DKO.scale = 0.5,0.5
;DKO.font   = 1,5
;DKO.text   = Double K.O.
DKO.displaytime = 60
DKO.snd    = 2,1

; Time Over
TO.offset  = 160, 120
TO.anim  = 710
TO.scale = 0.5,0.5
;TO.font    = 1,5
;TO.text    = Time Over
TO.displaytime = 60
TO.snd     = 2,0
KO.sndtime = 0               ;Time to play sound for KO, DKO and TO.
slow.time  = 60              ;Time for KO slowdown (in ticks)
over.waittime = 45           ;Time to wait after KO before player control is stopped
over.hittime = 10            ;Time after KO that players can still damage each other (for double KO)
over.wintime = 45            ;Time to wait before players change to win states
over.time = 210              ;Time to wait before round ends

; Time to wait before showing win/draw message
win.time = 60

; Win text
win.offset = 160,120
win.anim = 720
win.scale = 0.5,0.5
;win.font = 1,0
;win.text = %s Wins
win.displaytime = 540

; 2-players win text
win2.offset = 160,120
win2.anim = 720
win2.scale = 0.5,0.5
;win2.font = 1,0
;win2.text = %s and %s Win
win2.displaytime = 540

; Draw text
draw.offset = 160, 120
draw.anim  = 730
draw.scale = 0.5,0.5
;draw.font = 1,0
;draw.text = Draw Game
draw.displaytime = 540

