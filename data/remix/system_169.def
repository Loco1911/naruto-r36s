;==================================================================================================
;Attract mode definition
;Enable this mode to make Ikemen act like an arcade game
[Attract Mode]
enabled = 0
fadein.time = 10
fadein.col = 0, 0, 0
fadeout.time = 10
fadeout.col = 0, 0, 0
credits.key = "5"
options.key = "F11"
credits.snd = 400, 0
logo.storyboard = "../kfm/logo.def"
intro.storyboard = "../kfm/intro.def"
start.storyboard = ""
start.time = 600
start.insert.text = "Insert coin"
start.insert.offset = 640, 501
start.insert.font = 3, 0, 0
start.insert.scale = 1.0, 1.0
start.insert.blinktime = 30
start.press.text = "Press Start"
start.press.offset = 640, 501
start.press.font = 3, 0, 0
start.press.scale = 1.0, 1.0
start.press.blinktime = 30
start.timer.offset = 1089, 696
start.timer.font = 2, 0, -1
start.timer.scale = 1.0, 1.0
start.timer.text = "%i"
start.timer.count = 60
start.timer.framespercount = 60
start.timer.displaytime = 10
start.done.snd = 100, 1
credits.text = "CREDITS: %2i"
credits.offset = 640, 696
credits.font = 2, 0, 0
credits.scale = 1.0, 1.0

