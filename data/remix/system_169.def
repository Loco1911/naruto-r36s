;Order timer
; Change timer.count to positive number to enable order selection timer
timer.offset = 640, 635
timer.font = 8, 0, 0, 255, 255, 242
timer.scale = 1.0, 1.0
timer.text = "%i"
timer.count = 30
timer.framespercount = 6
timer.displaytime = 0

; Time to maintain versus screen after both sides confirm their order
; (in which order parameters are rendered using optional done variants)
done.time = 60

; This section only works on Orange-Dolphin's Palette Select branch
enablepalettes = 1


