p2.value.icon.member2.spr = 810, 5
p2.value.icon.member3.spr = 810, 5
p2.value.icon.member4.spr = 810, 5
p2.value.icon.offset = 900, 180
p2.value.icon.facing = 1
p2.value.icon.scale = 0.5, 0.5

