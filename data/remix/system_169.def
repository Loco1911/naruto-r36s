actionno = 140
layerno = 0
start = 380, 52


;==================================================================================================
[VS Screen]
time = 200
fadein.time = 20
fadeout.time = 20

;Match text in arcade modes
match.text = "Match %i" ;%i can be used for the match number
match.offset = 640, 85
match.font = 2, 0, 0

;Big portraits
p1.num = 4
p1.anim = 0
;p1.done.anim = 181
;p1.spr = 9000, 1
p1.offset = 480, 540
p1.facing = 1
p1.scale = 0.75, 0.75
p1.spacing = -100, 0
p1.padding = 1

p2.num = 4
p2.anim = 0
;p2.done.anim = 181
;p2.spr = 9000, 1
p2.offset = 800, 540
p2.facing = -1
p2.scale = 0.75, 0.75
p2.spacing = 100, 0
p2.padding = 1

;Names
p1.name.num = 1; (not used for co-op)
p1.name.offset = 300, 600
p1.name.font = 3, 0, 0
p1.name.spacing = 0, 45
p1.name.scale = 0.75, 0.75

p2.name.num = 1; (not used for co-op)
p2.name.offset = 980, 600
p2.name.font = 3, 0, 0
p2.name.spacing = -0, 45
p2.name.scale = 0.75, 0.75

;Order Select
orderselect.enabled = 1

;Keys
; By default all action buttons confirm currently selected order.
; Assign keys to 'p<pn>.member<num>.key' parameters to enable order
; selection on per team member basis.
p1.member1.key = "a"
p1.member2.key = "b"
p1.member3.key = "x"
p1.member4.key = "y"
p1.accept.key = "a&b&c&x&y&z&s"
p1.skip.key = "s"

p2.member1.key = "a"
p2.member2.key = "b"
p2.member3.key = "x"
p2.member4.key = "y"
p2.accept.key = "a&b&c&x&y&z&s"
p2.skip.key = "s"

;Order Buttons
; Icon elements are rendered on top of portraits, with positioning affected
; by portrait num, offset, spacing, and padding. Done variants replace
; spr/anim once order selection is completed.
;p1.member1.icon.anim = -1
p1.member1.icon.spr = 800, 0
;p1.member1.icon.done.anim = -1
;p1.member1.icon.done.spr =
