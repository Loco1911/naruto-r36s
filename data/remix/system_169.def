;Order Values
; Value icons are rendered on top of portraits, with positioning starting at
; 0, 0. empty.icon elements are replaced with icon upon order selection.
; If present, value.icon.member<num> parameters replace default value.icon
; on per team member basis.
;p1.value.icon.anim = -1
;p1.value.icon.spr =
p1.value.icon.member1.spr = 810, 0
p1.value.icon.member2.spr = 810, 0
p1.value.icon.member3.spr = 810, 0
p1.value.icon.member4.spr = 810, 0
p1.value.icon.offset = 380, 180
p1.value.icon.facing = 1
p1.value.icon.scale = 0.5, 0.5

