;==================================================================================================
; MUGEN 1 SCREENPACK REMIX by Phantom.of.the.Server
;==================================================================================================

[Info]
name = "Mugen 1 Screenpack Remix"
author = "Phantom.of.the.Server"; 99% of the work done by Elecbyte and the Ikemen GO team
versiondate = 2024
ikemenversion = 0.99
mugenversion = 1.1; Just in case. Not an actual Mugen screenpack
localcoord = 1280, 720


;==================================================================================================
[Files]
spr = system.sff       ;Filename of sprite data
snd = system.snd       ;Filename of sound data
logo.storyboard =      ;Logo storyboard definition (optional)
intro.storyboard =     ;Intro storyboard definition (optional)
font1 = font/f-4x6.def
font2 = font/name14.def
font3 = font/enter48.def
font4 = font/arcade.def
font5 = font/mssansserif-tt36.def
;font5.height = 36 ;Uncomment to override the size of the font (Truetype fonts only)
font6 = font/infofont.def
font7 = font/Open_Sans.def
font8 = font/num48.def
module = ;External Lua code

;Character and stage selection list
select = select.def

;fight = ../fight.def  ;Fight definition filename

;Fight definition filename
fight = ../mugen1_lifebar_remix/fight_169.def


;==================================================================================================
[Music]
 ;Put a filename for a MOD, MP3 or MIDI here, or just leave it
 ;blank if you do not want music. If an invalid filename is
 ;given, then no music will play.
 ;To play mymusic.mp3 from the sound/ directory, put:
 ; title.bgm = sound/mymusic.mp3
 ;Music will continue to play between screens if the files names
 ;are the same, and both BGMs are specified to loop.

 ;Music to play at title screen.
title.bgm = bgm/title.mp3
title.bgm.volume = 100
title.bgm.loop = 1
title.bgm.loopstart =
title.bgm.loopend =

 ;Music to play at char select screen.
select.bgm = bgm/select.mp3
select.bgm.volume = 100
select.bgm.loop = 1
select.bgm.loopstart =
select.bgm.loopend =

 ;Music to play at versus screen.
vs.bgm = bgm/versus.mp3
vs.bgm.volume = 100
vs.bgm.loop = 0
vs.bgm.loopstart =
vs.bgm.loopend =

 ;Music to play at victory screen.
victory.bgm = bgm/victory.mp3
victory.bgm.volume = 100
victory.bgm.loop = 0
victory.bgm.loopstart =
victory.bgm.loopend =

 ;Music to play at option screen.
option.bgm = bgm/title.mp3
option.bgm.volume = 100
option.bgm.loop = 1
option.bgm.loopstart =
option.bgm.loopend =

 ;Music to play at replay screen.
replay.bgm = bgm/title.mp3
replay.bgm.volume = 100
replay.bgm.loop = 1
replay.bgm.loopstart =
replay.bgm.loopend =

 ;Music to play at continue screen.
continue.bgm = bgm/continue.mp3
continue.bgm.volume = 100
continue.bgm.loop = 1
continue.bgm.loopstart =
continue.bgm.loopend =

 ;Music to play at results screen.
results.bgm = bgm/title.mp3
results.bgm.volume = 100
results.bgm.loop = 1
results.bgm.loopstart =
results.bgm.loopend =

 ;Music to play at hiscore screen.
hiscore.bgm = bgm/title.mp3
hiscore.bgm.volume = 100
hiscore.bgm.loop = 1
hiscore.bgm.loopstart =
hiscore.bgm.loopend =


;==================================================================================================
;Title screen definition
[Title Info]
fadein.time = 10
fadeout.time = 10
menu.pos = 850, 374
menu.item.font = 4, 0, 0, 160, 160, 160
menu.item.scale = 0.75, 0.75
menu.item.active.font = 4, 0, 0
menu.item.active.scale = 1.0, 1.0
menu.item.active.offset = 0, 2
menu.item.spacing = 0, 34

connecting.offset = 640, 393
connecting.font = 7, 0, 0
connecting.scale = 1.0, 1.0
connecting.host.text = "Waiting for player 2... (%s)"
connecting.join.text = "Now connecting to %s... (%s)"
;connecting.overlay.window = 0, 0, 1280, 720
connecting.overlay.col = 0, 0, 0
connecting.overlay.alpha = 0, 128
textinput.offset = 189, 393
textinput.font = 7, 0, 1
textinput.scale = 1.0, 1.0
textinput.name.text = "Enter Host display name, e.g. John.\nExisting entries can be removed with DELETE button."
textinput.address.text = "Enter Host IP address, e.g. 127.0.0.1\nCopied text can be pasted with INSERT button."
;textinput.overlay.window = 0, 0, 1280, 720
textinput.overlay.col = 0, 0, 0
textinput.overlay.alpha = 0, 128

; These parameters define the window in which the items are visible
; in.
menu.window.margins.y = 40, 34
menu.window.visibleitems = 8
menu.boxcursor.visible = 0 ;Set to 0 to disable default cursor display
menu.boxcursor.coords = -298, -35, 298, 6
; These are the sounds for cursor movement
cursor.move.snd = 100, 0
cursor.done.snd = 100, 1
cancel.snd = 100, 2

: Flexible submenu grouping.
;Full documentation of this feature is available on Ikemen GO features wiki

; Submenu: Arcade
menu.itemname.menuarcade = "ARCADE"
menu.itemname.menuarcade.arcade = "SINGLE MODE"
menu.itemname.menuarcade.teamarcade = "TEAM ARCADE"
menu.itemname.menuarcade.teamcoop = "TEAM CO-OP"
menu.itemname.menuarcade.back = "BACK"

; Submenu: Versus
menu.itemname.menuversus = "VS MODE"
menu.itemname.menuversus.versus = "1P VS 2P"
menu.itemname.menuversus.teamversus = "TEAM VERSUS"
menu.itemname.menuversus.versuscoop = "VERSUS CO-OP"
menu.itemname.menuversus.freebattle = "QUICK MATCH"
menu.itemname.menuversus.back = "BACK"

; Submenu: Story Mode
menu.itemname.storymode = "STORY"
; story arcs menu items are automatically added before storymode.back
menu.itemname.storymode.back = "BACK"

; Submenu: Network
menu.itemname.menunetwork = "NETWORK"
menu.itemname.menunetwork.serverhost = "HOST GAME"
menu.itemname.menunetwork.serverjoin = "JOIN GAME"
menu.itemname.menunetwork.back = "BACK"

; known IP addresses show up before serverjoin.back item
menu.itemname.menunetwork.serverjoin.joinadd = "NEW ADDRESS"
menu.itemname.menunetwork.serverjoin.back = "BACK"

; This group is hidden and should not be moved to other menus.
; It's opened automatically, after synchronization with online player.
menu.itemname.server.netplayversus = "VERSUS 2P"
menu.itemname.server.netplayteamcoop = "ARCADE CO-OP"
menu.itemname.server.netplaysurvivalcoop = "SURVIVAL CO-OP"
menu.itemname.server.back = "EXIT"

; Submenu: Practice
menu.itemname.menupractice = "PRACTICE"
menu.itemname.menupractice.training = "TRAINING"
;menu.itemname.menupractice.trials = "TRIALS"; (not implemented yet)
menu.itemname.menupractice.back = "BACK"

; Submenu: Mission
menu.itemname.menumission = "MISSION"
menu.itemname.menumission.survival = "SURVIVAL"
menu.itemname.menumission.survivalcoop = "SURVIVAL CO-OP"
menu.itemname.menumission.timeattack = "TIME ATTACK"
menu.itemname.menumission.bonusgames = "BONUS GAMES"
menu.itemname.menumission.back = "BACK"

; Submenu: Mission => Bonus Games
; bonus characters menu items are automatically added before bonusgames.back
menu.itemname.menumission.bonusgames.back = "BACK"

; Submenu: Watch Mode
menu.itemname.menuwatch = "WATCH MODE"
menu.itemname.menuwatch.watch = "CPU MATCH"
menu.itemname.menuwatch.randomtest = "RANDOMTEST"
menu.itemname.menuwatch.replay = "REPLAY"
menu.itemname.menuwatch.back = "BACK"

; Options
menu.itemname.options = "OPTIONS"

; Exit Game
menu.itemname.exit = "EXIT"


