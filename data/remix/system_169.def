p1.member4.icon.spr = 800, 3
;p1.member4.icon.done.anim = -1
;p1.member4.icon.done.spr =
p1.member4.icon.offset = 0, -380
p1.member4.icon.facing = 1
p1.member4.icon.scale = 1.0, 1.0

