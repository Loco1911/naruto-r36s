trigger1 = AnimTime = 0
value = 1000
;-------------------------------------------------------------------------------
; Intro 2
[Statedef 1011]
type    = A
movetype= I
physics = A
juggle  = 1
velset = 4,-4
ctrl = 0
anim = 102
sprpriority = 2

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0

[State 0, PosSet]
type = Posadd
trigger1 = time = 0
x = backedgebodydist - 15
y = -100

[State 0, VarSet]
type = VarSet
trigger1 = time = 0
v = 6
value = 200

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S40,1
volume = 50
;-------------------------------------------------------------------------------
; Walk FWD
[Statedef 1020]
type    = S
movetype= A
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 20
sprpriority = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 3||animelem = 6
value = S20,1
volume = 999

[State 20, 1]
type = VelSet
trigger1 = 1
x = const(velocity.walk.fwd.x)

[State 0, JUMP]
type = ChangeState
trigger1 = p2bodydist x < 100 && random < (var(2)) && p2bodydist y < -50
value = 40

[State 200, End]
type = ChangeState
trigger1 = p2bodydist x < 20
trigger2 = time > 20 && random < 250
value = 1000
