;===============================================================================
; Stance
[Statedef 1000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 0
sprpriority = 0

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30

[State 0, WALK FWD]
type = ChangeState
trigger1 = p2bodydist x > 30 && random < (var(2)*2)
value = 1020

[State 0, JUMP]
type = ChangeState
trigger1 = p2bodydist x < 100 && random < (var(2)) && p2bodydist y < -50
trigger2 = random < (var(2)/2)
value = 40

[State 0, Hop Back]
type = ChangeState
trigger1 = p2bodydist x < 50 && random < (var(2))
trigger2 = p2bodydist x < 50 && random < (var(2)*2) && p2movetype = A
value = 70

[State 0, Hit 1]
type = ChangeState
trigger1 = p2bodydist x < 35 && random < (var(2)*2)
value = 1200

[State 0, Hit 2]
type = ChangeState
trigger1 = p2bodydist x < 35 && random < (var(2)*2)
value = 1300

[State 0, Hit 3]
type = ChangeState
trigger1 = p2bodydist x < 35 && random < (var(2)*2)
value = 1400

[State 0, 800]
type = ChangeState
triggerall = power >= 500
trigger1 = p2bodydist x < 85 && random < (var(2)*4)
value = 800

[State 0, 810]
type = ChangeState
triggerall = power >= 500
trigger1 = random < (var(2)*4) && p2bodydist x < 40
value = 810

[State 0, 820]
type = ChangeState
triggerall = power >= 1000
trigger1 = random < (var(2)*4) && P2BodyDist X >= 100
value = 820

[State 0, 830]
type = ChangeState
triggerall = power >= 1000
trigger1 = random < (var(2)*4) && P2BodyDist X = [20,100]
value = 830

[State 0, 850]
type = ChangeState
triggerall = power >= 1500
trigger1 = random < (var(2)*4) && p2bodydist x < 35
value = 850

[State 0, 860]
type = ChangeState
triggerall = power >= 1500
trigger1 = random < (var(2)*4) && P2BodyDist X >= 100
value = 860

[State 200, End]
type = Changestate
trigger1 = var(6) <= 0
trigger2 = roundstate != 2
value = 1001
;-------------------------------------------------------------------------------
; Muerte 1
[Statedef 1001]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 170
sprpriority = 2

[State 0, ParentVarAdd] ; Counter
type = ParentVarAdd
trigger1 = time = 0
v = 3
value = 1

[State 0, ParentVarAdd] ; Life
type = ParentVarAdd
trigger1 = time = 0
v = 4
value = -25-random%25

[State 0, Roto]
type = Explod
trigger1 = time = 5
anim = 192
ID = 192
pos = 0,0
postype = p1
scale = .8,.8
sprpriority = 4
ontop = 1
ownpal = 1

[State 200, End]
type = Destroyself
trigger1 = AnimTime = 0
;-------------------------------------------------------------------------------
; Muerte 2
[Statedef 1002]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 5110
sprpriority = 0

[State 0, ParentVarAdd] ; Counter
type = ParentVarAdd
triggerall = roundstate = 2
trigger1 = time = 0
v = 3
value = 1

[State 0, ParentVarAdd] ; Life
type = ParentVarAdd
triggerall = roundstate = 2
trigger1 = time = 0
v = 4
value = -25-random%25

[State 0, NotHitBy]
type = NotHitBy
trigger1 = 1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 9999
ignorehitpause = 0

[State 0, PosSet]
type = PosSet
trigger1 = 1
y = 0

[State 0, Trans]
type = Trans
trigger1 = 1
trans = addalpha
alpha = 256-time*25,0+time*256

[State 200, End]
type = Destroyself
trigger1 = time = 10
