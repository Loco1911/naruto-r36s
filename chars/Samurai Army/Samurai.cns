v = 6
value = 200

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 2
value = S40,2
volume = 50

[State 0, Roto]
type = Explod
trigger1 = time = 5
anim = 192
ID = 192
pos = 0,0
postype = p1
scale = .8,.8
sprpriority = 4
ontop = 1
ownpal = 1

[State 200, End]
