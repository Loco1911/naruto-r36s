walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Solo lucho por mis ambiciones!"
victory1 = "Deberias sentirte orgulloso de que sea yo quien te mande al infierno."
victory2 = "No hay nadie que pueda contra mi Kubikiribocho!"
victory3 = "Me desafiaste. Supongo que eras conciente de lo que eso implicaba."

