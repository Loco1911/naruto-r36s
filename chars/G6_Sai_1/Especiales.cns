trigger1 = animelem = 3
attr = S, SA
animtype  = medium
damage    = 10
Hitflag = MAFDE
guardflag = MA
pausetime = 10,ifelse(time >= 140,20,40)
guard.pausetime = 5,10
sparkno = -1
guard.sparkno = s7000
sparkxy = -10,-30
hitsound   = -1
guardsound = -1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = 0
air.velocity = 0
Fall = 0
hitonce = 1
getpower = 0,0
envshake.time = 5

[State 1102, BindToTarget]
type = BindToTarget
trigger1 = !time && NumTarget
pos = 0, -target,const(size.height)/2
time = 150

[State 0, EnvShake]
type = EnvShake
trigger1 = AnimElem = 3
time = 5
freq = 30
ampl = -1
phase = 90

[State 1102, PlaySnd]
type = PlaySnd
trigger1 = AnimElem = 3
value = 1,20

[State 0, ParentVarSet]
type = ParentVarSet
trigger1 = enemy,life = 0
v = 6
value = 1

[State 200, End]
type = Changestate
trigger1 = ifelse(movehit,time = 150,time = 120)
trigger2 = root,movehit||(enemy,life = 0 && time >= 20)
value = 1104

