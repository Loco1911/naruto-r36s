;Ink Mouse
[StateDef 1001]
type = S
movetype = A
physics = N
velset = random/500.0*3+3,0
sprpriority = 3
anim = 1001

[State 1001, VelSet]
type = VelSet
trigger1 = time
x = 5

[State 1001, HitOverride]
type = HitOverride
trigger1 = !time
attr = SCA,AA,AP,AT
slot = 0
stateno = 1104
time = -1
forceair = 0

[State 1001, PlaySnd]
type = PlaySnd
trigger1 = !time
value = 1,14

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = unguardable

[State 200, 1]
type = HitDef
trigger1 = !time
attr = S, SP
animtype  = light
damage    = 30
guardflag = MA
Hitflag = MAFDE
pausetime = 7,7
sparkno = -1
guard.sparkno = s7000
sparkxy = -8,-25
hitsound   = S1,13
guardsound = S4,1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = -2,-1
air.velocity = -2,-1
Fall = 1
envshake.time = 3
sprpriority = 3

[State 200, Spark CVS]
type = Explod
triggerall = Numexplod(7001) = 0
trigger1 = Movehit = 1
anim = 7001
ID = 7001
postype = P1
pos = 5,-5
facing = 1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = 0.3,0.3
removeongethit = 1
ontop = 1
supermovetime 	= 999
ignorehitpause  = 1

[State 1001, ChangeState]
type = ChangeState
trigger1 = movecontact ||  FrontEdgeDist <= -5
value = 1104
