yscale = 1
ground.back = 13
ground.front = 13
air.back = 13
air.front = 13
height = 35
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -60
mid.pos = -5, -30
shadowoffset = 0
draw.offset = 0,0

[Velocity]
