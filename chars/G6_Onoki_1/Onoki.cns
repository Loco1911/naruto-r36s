airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Una fuerte confianza en uno mismo muestra el camino correcto!"
victory1 = "Conocer el dolor del pasado, permite tomar mejores decisiones en el futuro!"
victory2 = "Soy el tecer Tsuchikage, Onoki de las Dos Escalas! No me subestimes!"
victory3 = "Me prometi a mi mismo ganar este combate!"
victory4 = "Tu audacia no tiene limites."
