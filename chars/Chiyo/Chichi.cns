;===============================================================================
; Chichi:
;-------------------------------------------------------------------------------
; Stand
[Statedef 1900]
type    = S
movetype= I
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 4100
sprpriority = 0
ownpal = 1

[State 0, Desvanecerse]
type = ChangeState
trigger1 = numhelper(1960) > 0
value = 1990

[State 0, Desvanecerse]
type = ChangeState
trigger1 = numhelper(3350) = 1
value = 1989

[State 0, Desvanecerse]
type = ChangeState
trigger1 = root,stateno = [1251101,1251133]
value = 1998

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = time = 0
id = 1360

[State 0, 2 - 2]
type = ChangeState
trigger1 = root,stateno = 400 && root,time = 1
value = 405

[State 0, 2 - 3]
type = ChangeState
trigger1 = root,stateno = 410 && root,time = 1
value = 415

[State 0, 2 - 4]
type = ChangeState
trigger1 = root,stateno = 420 && root,time = 1
value = 425

[State 0, Special 2]
type = ChangeState
trigger1 = root,stateno = 1300 && root,time = 1
value = 1370

[State 0, Super 1]
type = ChangeState
trigger1 = root,stateno = 3000 && root,time = 1
value = 3020

[State 0, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = 1980
time = 999

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 0, PosSet]
type = PosSet
trigger1 = 1
y = -20

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -30
trigger2 = rootdist x < -80

[State 0, Walk FWD]
type = ChangeState
trigger1 = rootdist x > 80
value = 1920

[State 0, DestroySelf]
type = DestroySelf
trigger1 = time = -1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = root,var(2) = 1
trigger2 = numhelper(560) = 1
flag = Invisible
flag2 = Noshadow

;-----------------------

[State 0, ChangeState]
type = Changestate
trigger1 = parent,win
trigger2 = parent,drawgame
trigger3 = parent,lose
value = 1999
