; Haha hacia P2 - Start
[Statedef 1960]
type    = S
movetype= A
physics = S
juggle  = 1
ctrl = 0
anim = 1270
sprpriority = 3
ownpal = 1

[State 0, PosSet]
type = PosSet
trigger1 = time = 0
x = helper(1900),pos x
y = -25

[State 0, Turn]
type = Turn
triggerall = p2bodydist x < - 30
trigger1 = time = 0

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 0, PlayerPush]
type = PlayerPush
trigger1 = 1
value = 0

[State 1050,Afterimage]
type = AfterImage
trigger1 = time = 0
time = 50
trans = Add
length = 9
timegap = 1
framegap = 1
palbright = 0 , 0 , 0
palcontrast = 100, 100, 100
paladd = 0,0,0
palmul = .90, .90, .90

[State 0, VelSet]
type = VelSet
triggerall = time > 1
trigger1 = 1
x = 10

[State 200, 1]
type = HitDef
triggerall = !movecontact
trigger1 = 1
attr = A, SP
animtype  = heavy
damage    = 10,5
guardflag = MA
pausetime = 0,10
sparkno = -1
guard.sparkno = -1
sparkxy = 0,0
hitsound   = -1
guardsound = -1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = 0
air.velocity = 0
Fall = 0
getpower = 0,0

[State 0, Guard Spark]
type = Explod
triggerall = numexplod(7000) = 0
trigger1 = moveguarded = 1
anim = 7000
ID = 7000
postype = P2
pos = 8,-30
facing = 1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = .5,.5
removeongethit = 1
ontop = 1
ignorehitpause = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 1
value = S1212,22
volume = 999

[State 200, End]
type = Destroyself
trigger1 = time >= 200
trigger2 = frontedgebodydist <= 0
trigger3 = backedgebodydist <= 0

[State 0, Humo]
type = Explod
trigger1 = time >= 200
trigger2 = frontedgebodydist <= 0
trigger3 = backedgebodydist <= 0
anim = 2000
ID = 2000
pos = 10,-30
postype = p1
facing = 1
vfacing = 1
bindtime = 1
removetime = -2
scale = .3,.3
sprpriority = 4
ontop = 1
ownpal = 1
removeongethit = 0
supermove = 999

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time >= 200
trigger2 = frontedgebodydist <= 0
trigger3 = backedgebodydist <= 0
value = S0,27
volume = 50

[State 200, End]
