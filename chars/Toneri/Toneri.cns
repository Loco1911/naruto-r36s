;===============================================================================
;-----------------Constantes y Ataques normales---------------------------------
;===============================================================================

;Var List:

; - Var(2) = Rikudou Mode
; - Var(3) = Rikudou Full Power
; - Var(4) = Lifeadd Full Power
; - Var(5) = Limitador Air Jump
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = Limbo Hengoku
; - Var(12) = Oscurecer Pantalla

[Data]
life = 1000
power = 3000
attack = 100
defence = 100
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 0.83
yscale = 0.83
ground.back = 13
ground.front = 13
air.back = 13
air.front = 13
height = 60
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 2
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82
;===============================================================================
; Guododama
;-------------------------------------------------------------------------------
[Statedef 2]
type    = A
movetype= I
physics = N
juggle  = 1
anim = 2
sprpriority = 0


; COMMON

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 0, Pos]
type = PosAdd
trigger1 = 1
x = rootdist x - 7
y = rootdist y - 70

; INVISIBILIDAD:

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = root,numexplod(2160) > 0
trigger2 = numhelper(2215) > 0
trigger3 = numhelper(2315) > 0
trigger4 = numhelper(2325) > 0
trigger5 = numhelper(2415) > 0
trigger6 = numhelper(3150) > 0
trigger7 = root,stateno = 3100
trigger8 = root,stateno = 2192
trigger9 = root,stateno = 2400
trigger10 = root,stateno = 2410
trigger11 = root,stateno = 2420
trigger12 = root,stateno = 4100
trigger13 = root,stateno = 4200
trigger14 = root,stateno = 3500
trigger15 = root,stateno = 3501
trigger16 = root,stateno = 3000
trigger17 = root,stateno = 3502
trigger18 = root,stateno = 2170
flag = Invisible
flag2 = Noshadow

; POS:

[State 0, Pos Turn]
type = PosAdd
trigger1 = root,anim = 5+root,var(11)
y = rootdist y - 60

[State 0, Pos Crouch]
type = PosAdd
trigger1 = root,stateno = [10,12]
trigger2 = root,stateno = 40
trigger3 = root,stateno = 52
y = rootdist y - 50
x = rootdist x

[State 0, Pos Walk]
type = PosAdd
trigger1 = root,stateno = 20
trigger2 = root,stateno = 50
trigger3 = root,stateno = 2060
trigger4 = root,stateno = 2070
y = rootdist y - 55

[State 0, Pos Hurt]
type = PosAdd
trigger1 = root,stateno = [5000,5299]
y = rootdist y - 50

[State 0, Pos 2220]
type = PosAdd
trigger1 = root,stateno = 2220
x = rootdist x - 15
y = rootdist y - 70

[State 0, Pos 2221]
type = PosAdd
trigger1 = root,stateno = 2221 && root,time < 22
x = rootdist x + 10
y = rootdist y - 45

[State 0, Pos 2230]
type = PosAdd
trigger1 = root,stateno = 2230 && root,time > 10
x = rootdist x
y = rootdist y -60

[State 0, Pos 2300 // 2320]
type = PosAdd
trigger1 = root,stateno = 2300
trigger2 = root,stateno = 2320
x = rootdist x
y = rootdist y -70

[State 0, Pos 2310]
type = PosAdd
trigger1 = root,stateno = 2310
x = rootdist x -10
y = rootdist y -65

[State 0, Pos 2600]
type = PosAdd
trigger1 = root,stateno = 2600
x = rootdist x - 7
y = rootdist y - 55

[State 0, Pos 2610]
type = PosAdd
trigger1 = root,stateno = 2610
x = rootdist x + 10
y = rootdist y - 45

[State 0, Pos 2620]
type = PosAdd
trigger1 = root,stateno = 2620
x = rootdist x - 15
y = rootdist y - 60

[State 0, Pos 3000]
type = PosAdd
trigger1 = root,stateno = 3000 && root,time < 30
x = rootdist x - 15
y = rootdist y - 50

[State 0, Pos 3000]
type = PosAdd
trigger1 = root,stateno = 3000 && root,time >= 30
x = rootdist x - 0
y = rootdist y - 60

[State 0, Pos 3300]
type = PosAdd
trigger1 = root,stateno = 3300
x = rootdist x - 2
y = rootdist y - 65

[State 0, Pos 2170]
type = PosAdd
trigger1 = root,stateno = 2170 && root,time > 5
x = rootdist x
y = rootdist y - 50

;x = rootdist x - 7
;y = rootdist y - 70

; SPRPRIORITY:

[State 0, SprPriority]
type = SprPriority
trigger1 = root,stateno = 2189 && root,time = 18
trigger2 = root,stateno = 2210 && root,time = 5
trigger3 = root,stateno = 2221 && root,time = 1
trigger4 = root,stateno = 2300 && root,time = 5
trigger5 = root,stateno = 2310 && root,time = 5
trigger6 = root,stateno = 2320 && root,time = 5
value = 3


[State 0, SprPriority]
type = SprPriority
trigger1 = root,stateno != 2189
trigger1 = root,stateno != 2210
trigger1 = root,stateno != 2221
trigger1 = root,stateno != 2300
trigger1 = root,stateno != 2310
trigger1 = root,stateno != 2320
trigger1 = root,stateno != 2610
trigger1 = root,stateno != 3300
trigger2 = root,stateno = 2189 && root,time = 18
trigger3 = root,stateno = 2210 && root,animelem = 6
trigger4 = root,stateno = 2221 && root,animelem = 5
trigger5 = root,stateno = 2300 && root,animelem = 6
trigger6 = root,stateno = 2310 && root,animelem = 6
trigger7 = root,stateno = 2320 && root,animelem = 6
trigger8 = root,stateno = 2610 && root,animelem = 6
trigger9 = root,stateno = 3300 && root,animelem = 4
value = 0

[State 200, End]
type = Destroyself
trigger1 = root,var(2) = 0
trigger2 = root,stateno = 2182 && root,time >= 140
