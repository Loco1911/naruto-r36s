; Ninja Tools:
;-------------------------------------------------------------------------------
; Ninja Tools - Start
[Statedef 8000]
type    = S
movetype= A
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 8000
poweradd = -300
sprpriority = 2

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,21
volume = 999

[State 0, Burbuja 1]
type = Helper
trigger1 = time = 20
helpertype = Normal
name = "Burbuja 1"
ID = 8050
stateno = 8050
pos = 55,-45
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
size.xscale = .5
size.yscale = .5

[State 200, End]
type = ChangeState
Triggerall = power >= 200
triggerall = time >= 30
trigger1 = ailevel = 0 && command = "z"
trigger2 = ailevel > 0 && roundstate = 2 && random = [600,800]
value = 8001

[State 200, Run + Run IA]
type = ChangeState
triggerall = time >= 40
trigger1 = ailevel = 0 && command = "FF"
trigger2 = ailevel > 0 && random < (ailevel * 100)
value = 60

[State 200, End]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1

