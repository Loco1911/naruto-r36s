;===============================================================================
; Guard Break Charge :
;-------------------------------------------------------------------------------
[Statedef 8500]
type    = S
movetype= I
physics = S
ctrl = 0
anim = 8500
velset = 0,0
sprpriority = 0

[State 0, Onda FX]
type = Helper
trigger1 = time = 0
trigger2 = time = 31
helpertype = normal
name = "Onda FX"
ID = 8510
stateno = 8510
pos = -2,-23
postype = p1
facing = 1
keyctrl = 0
ownpal = 1
size.xscale = .5
size.yscale = .5

[State 0, PalFXWiz]
type = PalFX
trigger1 = time = 0
trigger2 = time = 31
time = 10
add = 180,180,180
mul = 256,256,256
sinadd = 0,0,0,1
color = 256
removeongethit = 1
[State 300, 1]
type = PlaySnd
trigger1 = time = 0
trigger2 = time = 31
value = S2,25
volume = 999
[State 300, 1]
type = PlaySnd
trigger1 = time = 0
trigger2 = time = 31
value = S2,25
volume = 999

[State 200, Jump]
type = ChangeState
triggerall = time >= 15
trigger1 = ailevel = 0 && command = "holdup"
value = 40
[State 200, Back]
type = ChangeState
triggerall = time >= 15
trigger1 = ailevel = 0 && command = "holdback"
value = 70

[State 200, End]
type = ChangeState
triggerall = ailevel = 0
triggerall = time >= 15
trigger1 = command != "hold_z"
trigger2 = time = 60
value = ifelse(time > 59,8502,8501)

[State 200, End]
type = ChangeState
triggerall = ailevel > 0
triggerall = time >= 15
trigger1 = time = 60
trigger2 = p2bodydist x < 80
value = ifelse(time > 59,8502,8501)
