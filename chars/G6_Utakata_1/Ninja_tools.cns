; Shuriken - Kunai
[Statedef 8054]
type    = S
movetype= A
physics = S
juggle  = 1
ctrl = 0
anim = 8050
sprpriority = 4

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S4,0
volume = 999

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 0, HitOverride]
type = HitOverride
trigger1 = 1
attr = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
stateno = 8051
time = 999999999
ignorehitpause = 1

[State 1050, VarRandom]
type = VarRandom
trigger1 = !time
v = 9
range = -300,250

[State 1050, VelSet]
type = VelSet
trigger1 = 1
x = 4
y = var(9)/300.0

[State 200, 1]
type = HitDef
triggerall = !movecontact
trigger1 = 1
attr = S, NA
animtype  = medium
damage    = 1
Hitflag = MAFDE
guardflag = MA
pausetime = 5,15
sparkno = -1
guard.sparkno = S7000
sparkxy = -8,-25
hitsound   = S4,3
guardsound = S4,1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = -4,-6
air.velocity = -4,-4
Fall = 0
getpower = 0,0
envshake.time = 3
PalFX.time = 20
palfx.add = 0,50,240
palfx.mul = 120,224,150

[State 200, Spark CVS]
type = Explod
triggerall = Numexplod(7001) = 0
trigger1 = Movehit = 1
anim = 7001
ID = 7001
postype = P1
pos = 10,0
facing = ifelse(random< 500,1,-1)
vfacing = ifelse(random< 500,1,-1)
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = 0.3,0.3
removeongethit = 1
ontop = 1
supermovetime 	= 999
ignorehitpause  = 1

[State 200, Spark CVS]
type = Explod
triggerall = Numexplod(7011) = 0
trigger1 = movecontact = 1
trigger2 = pos Y >= 0
trigger3 = frontedgebodydist <= -5
trigger4 = time >= 500
anim = 510
ID = 7011
postype = P1
pos = 0,0
facing = -1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = .2,.2
removeongethit = 1
ontop = 1
ignorehitpause  = 1

[State 0]
type = DestroySelf
trigger1 = movecontact
trigger2 = moveguarded
trigger3 = pos y >= -5
trigger4 = frontedgebodydist <= -5
trigger5 = time >= 500

