;-------------------------------------------------------------------------------
; Zetsu Central Desactivado
[Statedef 1999]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 9999
sprpriority = 0

[State 0, VarSet]
type = VarSet
trigger1 = time = 0
v = 4
value = lifemax

[State 0, LifeSet]
type = LifeSet
trigger1 = 1
value = var(4)

[State 0, Turn]
type = Turn
triggerall = roundstate = 2
trigger1 = timemod = 100,0 && random < 500

[State 0, PosSet]
type = PosSet
trigger1 = 1
x = ifelse(facing = 1,-500,500)
y = 0

[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0

[State 0, Zetsus]
type = Helper
triggerall = numhelper(1000) < 6
triggerall = life > 0
triggerall = roundstate = 2
trigger1 = timemod = 100,0
helpertype = player
name = "Zetsus"
ID = 1000
stateno = ifelse(random < 500,1011,1010)
pos = -250+random%500,0
postype = p1
facing = 1
ownpal = 1

[State 0, ChangeState]
type = ChangeState
trigger1 = roundstate > 2
value = 0
ctrl = 1
