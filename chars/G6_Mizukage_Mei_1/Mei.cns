walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Lamento decirtelo, pero las mujeres no siempre somos dulces."
victory1 = "Ver esto una y otra vez resulta doloroso, pero tienes que desparecer."
victory2 = "No subestimes el titulo de Mizukage!"
victory3 = "Me gusta la gente que le cuesta derretirse, pero contigo hare una excepcion."
victory4 = "Hay una gran diferencia entre la sed de sangre y el terror."
