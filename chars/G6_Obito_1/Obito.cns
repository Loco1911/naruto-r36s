airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "En un mundo de desesperacion. No vale la pena que existas."
victory1 = "En este mundo no existe la esperanza!"
victory2 = "La paz verdadera no existe. Ni tampoco la esperanza!"
victory3 = "Todos los ninjas que sobreviven a este mundo se convierten en basura."
victory4 = "Este mundo ya no es de mi incumbencia."
victory5 = "Cortare el destino de esta realidad."
victory6 = "La esperanza a la que te aferras no existe."
