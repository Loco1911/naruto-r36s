walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Hay cosas que debo proteger con mi vida!"
victory1 = "Puede que seas mi enemigo, pero siento aprecio por ti."
victory2 = "No puedo perder... No mientras sea Hokage."
victory3 = "La Voluntad de fuego arde en mi interior... Por eso puedo luchar hasta el final!"
victory4 = "Creiste estar a la altura de mi velocidad?"
