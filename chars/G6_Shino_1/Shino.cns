; Insects
[Statedef 191]
Type = S
Ctrl = 0
Anim = 9999
VelSet = 0,0
Physics = N

[State 0, Explod]
Type = Explod
Trigger1 = Time >= 2 && Time <= 102
Anim = 2002
ID = 2002
Pos = 0, -Floor(Pos Y)
PosType = P1
Facing = 1 - 2*(Random<500)
VFacing = 1 - 2*(Random<500)
BindTime = 1
RemoveTime = -2
Vel = 0,-(Time)/102.0
SuperMoveTime = -1
PauseMoveTime = -1
Scale = FVar(0), FVar(0)
SprPriority = 10 - 20*(Vel X < 0)
IgnoreHitPause = 1

[State 0, Explod]
Type = Explod
Trigger1 = Time >= 2 && Time <= 205
Anim = 2002
ID = 2002
Pos = 0,0
PosType = P1
Facing = 1 - 2*(Random<500)
VFacing = 1 - 2*(Random<500)
BindTime = 1
RemoveTime = -2
SuperMoveTime = -1
PauseMoveTime = -1
Scale = FVar(0), FVar(0)
SprPriority = 10 - 20*(Vel X < 0)
IgnoreHitPause = 1

[State 0, Null]
Type = Null
Trigger1 = Time < 102
Trigger1 = FVar(0) := FVar(0) + 0.0025
Trigger2 = Time > 172
Trigger2 = FVar(0) := (Random%50)/150.0
IgnoreHitPause = 1

[State 0, VelSet]
Type = VelSet
Trigger1 = Root, AnimElemTime(40) <= 0
X = (Cos(Time/20.0*PI)*25.0)/10.0
Y = -((Sin(GameTime/20.0*PI)*FVar(0))/20.0)

[State 0, PosAdd]
Type = PosAdd
Trigger1 = Time < 155 && !(Time%4)
Y = -2

[State 0, VelSet]
Type = VelSet
Trigger1 = Root, AnimElemTime(40) > 0 && Root, AnimElemTime(46) < 0
Y = ((RootDist Y)-30.0)/20.0
X = ((RootDist X)-50.0)/35.0

[State 0, VelSet]
Type = VelSet
Trigger1 = Root, AnimElemTime(46) >= 0 && Root, AnimElemTime(50) < 0
Y = .15
X = .4

[State 0, DestroySelf]
Type = DestroySelf
Trigger1 = !(Root, AnimElemTime(50))
IgnoreHitPause = 1
