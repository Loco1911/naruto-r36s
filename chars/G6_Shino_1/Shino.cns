airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Este combate no fue ningun problema."
victory1 = "Por cortesia hacia mi rival, nunca tengo piedad."
victory2 = "Aun no has sufrido el dolor de los insectos parasitos."
victory3 = "Asi luchamos los del clan Aburame."
victory4 = "Vaya... parece que llame demasiado la atencion."
