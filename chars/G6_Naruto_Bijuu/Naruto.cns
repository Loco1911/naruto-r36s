;Var List:

; - Var(2) = KCM Mode
; - Var(3) = Bijuu Mode
; - Var(4) = Ashura Mode
; - Var(5) = Kurama Chakra
; - Var(6) = Lifeadd Kurama Mode
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(10) = Apariencia Transformaciones
; - Var(11) = Golpeado Transformaciones
; - Var(12) = Oscurecer Pantalla
; - Var(13) = Ropa Rota
; - Var(14) = Ropa Rota Mantener
; - Var(15) = NO TOCAR
; - Var(16) = NO TOCAR
; - Var(17) = NO TOCAR
; - Var(18) = Kuchiyose Yatai Kuzushi no Jutsu
; - Var(55) = Choques

[Data]
life = 1000
power = 3000
attack = 100
defence = 100
fall.defence_up = 50
liedown.time = 60
airjuggle = 15
sparkno = -1
guard.sparkno = -1
KO.echo = 0
volume = 0
IntPersistIndex = 60
FloatPersistIndex = 40

[Size]
xscale = 1
yscale = 1
ground.back = 15
ground.front = 15
air.back = 15
air.front = 15
height = 50
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -50
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Sere el proximo hokage! No pienso detenerme ahora!"
victory1 = "El vinculo que he conseguido... No quiero romperlo ni que nadie lo rompa."
victory2 = "Nunca Falto a mi palabra! Ese es mi camino ninja!"
victory3 = "Es imposible que perdamos. Verdad, Kurama?"
