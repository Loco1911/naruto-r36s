;Var List:

; - Var(2) = KCM Mode
; - Var(3) = Bijuu Mode
; - Var(4) = Ashura Mode
; - Var(5) = Kurama Chakra
; - Var(6) = Lifeadd Kurama Mode
; - Var(7) = NO TOCAR
; - Var(8) = NO TOCAR
; - Var(9) = IA
; - Var(10) = Apariencia Transformaciones
