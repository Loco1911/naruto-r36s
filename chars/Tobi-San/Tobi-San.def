; Definition file for Tobi-San
; Contains all the filenames needed for the character

; Player information
[Info]
name = "Tobi-San"        ;Name of character
displayname = "Tobi-San" ;Name of character to display
versiondate = 05,23,2006    ;Version date of character (MM-DD-YYYY)
mugenversion = 04,14,2002   ;Version of M.U.G.E.N character works on
author = "Jerrydrizzt"         ;Character author name
pal.defaults = 1      ;Default palettes in order of preference

; Files for the player
[Files]
cmd     = Tobi-San.cmd   ;Command set
cns     = Tobi-San.cns   ;Constants
st      = Tobi-San.cns   ;States
stcommon = common.cns ;Common states
sprite  = Tobi-San.sff   ;Sprite
anim    = Tobi-San.air   ;Animation
sound   = Tobi-San.snd   ;Sound
pal1    = Tobi-San.act  ;Palettes (can have up to 12)
Pal2    = Blue.act
pal3    = Green.act
pal4    = Yellow.act
pal5    = Purple.act
pal6    = Gray.act

; Arcade mode
;[Arcade]
;intro.storyboard = intro.def
;ending.storyboard = ending.def
