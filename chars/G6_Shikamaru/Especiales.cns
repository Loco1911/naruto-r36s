;===============================================================================
;----------------------Especiales-----------------------------------------------
;===============================================================================
;===============================================================================
; Nipou Kage Nui:
;-------------------------------------------------------------------------------
[Statedef 1000]
type    = S
movetype= A
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 1000
poweradd = -1000
sprpriority = 2

[State 3000, SuperPause]
type = SuperPause
trigger1 = time = 0
time = 30
movetime = 30
anim = -1
sound = -1
pos = 32,-80
darken = 0
unhittable = 1

[State 3000, VarSet]
type = Varset
trigger1 = time = 0
v = 12
value = -100

[State 3000, VarAdd]
type = VarAdd
trigger1 = time >= 15 && Var(12) < 0
v = 12
value = 6

[State 3000, BGColorFX]
type = BGPalFX
trigger1 = Time > 0
time = 1
add = Var(12),Var(12),Var(12)

[State 3000, Super Charge]
type = Explod
trigger1 = Time = 0
anim = 7400
ID = 7400
pos = 2,-25
sprpriority = 2
supermove = 1
removetime = -2
bindtime = -1
ownpal = 1
scale = .7,.7
removeongethit = 1
ontop = 1
supermovetime 	= 999
ignorehitpause  = 1

[State 3000, PlaySnd - Super Charge]
type = PlaySnd
trigger1 = Time = 0
value = S950,1
volume = 50

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 3
value = S5,15
volume = 50

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,4
volume = 999
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,4
volume = 999

[State 1000, AssertSpecial]
type = AssertSpecial
trigger1 = AnimElemTime(3)>=0
flag = noshadow

[State 1000, Helper]
type = Helper
trigger1 = AnimElemTime(3)>=30 && !NumHelper(1001)
helpertype = normal ;player
name = "SHADOW HELPER"
ID = 1001
stateno = 1001
pos = 6,0
postype = p1    ;p2,front,back,left,right
facing = 1
keyctrl = 0
ownpal = 1
persistent = 0

[State 1000, ChangeState]
type = ChangeState
trigger1 = !NumHelper(1001) && AnimElemTime(3)>=86
value = 12
ctrl = 1
;----------------------------------------------------------------------
;Expandable Shadow
[StateDef 1001]
type = A
movetype = I
physics = N
anim = 1001
velset = 0,0
ctrl = 0
sprpriority = -1

[State 1001, BindToRoot]
type = BindToRoot
trigger1 = 1
time = 2
pos = 0,0

[State 1001, PlaySnd]
type = PlaySnd
trigger1 = !time
value = 2,5
channel = 1

[State 1001, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow

[State 1001, VarSet]
type = VarSet
trigger1 = !time
fvar(0) = 1.0

[State 1000, VarSet]
type = VarSet
trigger1 = (fvar(0)*32.0) >= (root,P2BodyDist X+50)
var(5) = 1

[State 1001, VarAdd]
type = VarAdd
trigger1 = (fvar(0)*32.0) < (root,P2BodyDist X+50)
fv = 0
value = .2

[State 1001, AngleDraw]
type = AngleDraw
trigger1 = 1
scale = fvar(0), 1

[State 1001, Helper]
type = Helper
triggerall = SelfAnimExist(root,stateno+2) && root,stateno=[1000,1405]
trigger1 = var(5) && !NumHelper(1002)
helpertype = normal ;player
name = "KAGE NUI"
ID = 1002
stateno = root,stateno+2
pos = floor(fvar(0)*32.0)-25,0
postype = p1    ;p2,front,back,left,right
facing = 1
keyctrl = 0
ownpal = 1
persistent = 0
size.xscale = 1
size.yscale = 1

[State 1001, VarAdd]
type = VarAdd
trigger1 = var(5) && !NumHelper(1002)
fv = 0
value = -.4

[State 1001, StopSnd]
type = StopSnd
trigger1 = var(5)
channel = 1

[State 1001, DestroySelf]
type = DestroySelf
trigger1 = (fvar(0)*32.0) <= 1.0
trigger2 = root,stateno!=[1000,1405]

