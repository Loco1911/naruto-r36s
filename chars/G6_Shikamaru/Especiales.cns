trigger1 = time % 40 = 29
value = -35

[State 1103, PlaySnd]
type = PlaySnd
trigger1 = time % 40 = 29
value = S1,18

[State 0, EnvShake]
type = EnvShake
trigger1 = time % 40 = 29
