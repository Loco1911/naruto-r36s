; NORMALES:
;-------------------------------------------------------------------------------
[State 0, Mordisco]
type = ChangeState
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
trigger1 = command = "a"
trigger2 = ailevel > 0 && p2bodydist x = [0,150]
trigger2 = random < 50
trigger2 = enemy,pos y < -50
value = 3430

[State 0, Manotazo]
type = ChangeState
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
trigger1 = command = "b"
trigger2 = ailevel > 0 && p2bodydist x = [50,250]
trigger2 = random < 50
trigger2 = enemy,pos y < -50
value = 3432

[State 0, Bijuudama Normal]
type = ChangeState
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
trigger1 = command = "c"
trigger2 = ailevel > 0 && p2bodydist x = [150,250]
trigger2 = random < 50
value = 3433

[State 0, Bijuudama Aire]
type = ChangeState
Triggerall = power >= 500
Triggerall = pos y < -30
triggerall = stateno = 3440
trigger1 = command = "a" || command = "b" || command = "c"
trigger2 = ailevel > 0 && p2bodydist x >= 100
trigger2 = time < 5 && time > 2 && random < 50
value = 3439

[State -1, Power Charge]
type = changestate
triggerall = power < 5000
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
trigger1 = command = "y"
value = 3450

[State -1, Power Charge IA]
type = changestate
triggerall = power < 5000
triggerall = RoundState = 2 && ailevel > 0
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
triggerall = P2BodyDist X >= 200
trigger1 = power < 1000 && Random = [600,800]
trigger2 = power < 2000 && power > 1000 && Random = [300,500]
trigger3 = power < 3000 && power > 2000 && Random = [100,200]
trigger4 = power < 4000 && power > 3000 && Random = [50,100]
trigger5 = power < 5000 && power > 4000 && Random = [25,50]
value = 3450
;-------------------------------------------------------------------------------
; Sonidos Comunes:
;-------------------------------------------------------------------------------
[State 0, Saltando]
type = PlaySnd
triggerall = stateno = 3440
trigger1 = Time = 1
value = S60,1
volume = 55
channel = -1

[State 0, Run]
type = PlaySnd
triggerall = stateno = 60||stateno = 70
trigger1 = time = 1
value = S40,2
volume = 50

[State 0, RemoveExplod]
type = RemoveExplod
TRIGGERALL = stateno != 3450
trigger1 = time = 1
id = 550

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 3450
trigger1 = time = 1
channel = 1

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 3450
trigger1 = time = 1
channel = 2

[State 0, EnvShake]
type = EnvShake
trigger1 = time = 1 && stateno = 3441
time = 15
freq = 60
ampl = -2
phase = 90
