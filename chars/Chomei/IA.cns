;[Statedef -2]
;===============================================================================
;---------------------------Estados usados Siempre------------------------------
;===============================================================================
[Statedef -3]
;===============================================================================
; Pared Rota:
;-------------------------------------------------------------------------------
[State 0, Helper]
type = Helper
triggerall = numhelper(450) = 0
trigger1 = p2stateno = 436
helpertype = normal
name = "Pared Rota"
ID = 450
stateno = 450
pos = 0,-30
postype = p2
facing = 1
keyctrl = 0
ownpal = 1
;===============================================================================
; Gyuki IA:
;-------------------------------------------------------------------------------
[State 0, Stand]
type = ChangeState
Triggerall =  stateno != [180,181]
Triggerall =  stateno != [34988,34989]
triggerall = pos y >= 0
triggerall = roundstate = 2
Trigger1 =  stateno != [3401,3499]
value = 3401

[State 0, JUMP]
type = ChangeState
triggerall = time >= 5
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
trigger1 = command = "holdup"
trigger2 = ailevel > 0 && p2bodydist x = [0,150]
trigger2 = p2statetype = A && random < 40
value = 3440

;[State 0, GUARD]
;type = ChangeState
;triggerall = stateno = 3401||stateno = 3420||stateno = 3421
;trigger1 = command = "holddown"
;trigger2 = ailevel > 0 && (p2movetype = A || (enemy, NumProj >= 1)) && p2bodydist x = [0,100]
;trigger2 = random < 25
;value = 3470

[State 0, NotHitBy]
type = NotHitBy
trigger1 = stateno = [3400,3499]
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 10

[State 0, Aura Susano]
type = Explod
triggerall = stateno = 3401||stateno = 3420||stateno = 3421
trigger1 = numexplod(9026) < 1 ;&& stateno = [3401,3499]
anim = 10100
ID = 9026
pos = 0,floor(-pos y)
postype = p1
facing = 1
vfacing = 1
bindtime = -1
removetime = -1
scale = 1,1
sprpriority = -2
ontop = 0
ownpal = 1
removeongethit = 1
trans = addalpha
alpha = 250,256

[State 0, RemoveExplod]
type = RemoveExplod
trigger1 = pos y < 0
trigger2 = stateno = 3470
ID = 9026

[State 0, Gyuki Escudo Invisible]
type = Helper
triggerall = numhelper(34988) = 0
trigger1 = stateno = [3401,3499]
helpertype = player
name = "Gyuki Escudo Invisible"
ID = 34988
stateno = 34988
pos = 0,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 1

[State 0, LifeAdd]
type = LifeAdd
trigger1 = stateno = [3400,3499]
value = var(6)
