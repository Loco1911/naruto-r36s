airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Incluso las flores hermosas mas pueden tener espinas!"
victory1 = "El amor hace mas fuerte a las personas! No infravalores a las mujeres!"
victory2 = "Yo tambien llevo el nombre del clan Yamanaka. No me subestimes!"
victory3 = "Debido a mi belleza extrema soy objeto de envidia y admiracion!"
victory4 = "Hermosa y violenta! Florecere en el campo de batalla!"
