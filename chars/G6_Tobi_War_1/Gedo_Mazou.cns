;===================================================================================
;---------------- Susanoo Perfecto --------------------------------------------
;===============================================================================
; Susanoo Stand:
;-------------------------------------------------------------------------------
[Statedef 4000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 4048
sprpriority = 3

[State 0]
type = AssertSpecial
trigger1 = 1
flag = invisible

[State 0, PosSet]
type = PosSet
trigger1 = 1
y = -230;-150

[State 0, NotHitBy]
type = NotHitBy
trigger1 =  1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 10

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -40

[State 0, Walk]
type = VelSet
trigger1 = command = "holdfwd" || command = "holdback"
x = ifelse(command = "holdfwd",1.5,-1.5)

[State 0, Walk FWD]
type = ChangeAnim
triggerall = anim != 4048
trigger1 = vel x >= 0
value = 4048

[State 0, Walk Back]
type = ChangeAnim
triggerall = anim != 4049
trigger1 = vel x < 0
value = 4049

[State 0, Walk IA]
type = VelSet
trigger1 = RoundState = 2 && ailevel > 0 && p2bodydist x >= 100
trigger1 = random < 30
x = 1.5

[State 0, Walk IA]
type = VelSet
trigger1 = RoundState = 2 && ailevel > 0 && p2bodydist x > 50 && vel x > 0
trigger1 = 1
x = 1.5

[State -1, Mountains Cutter]
type = ChangeState
Triggerall = power >= 2000
trigger1 = command = "holddown"
trigger1 = command = "a"
trigger2 = RoundState = 2 && ailevel > 0 && P2BodyDist X = [-50,75]
trigger2 = random < 100
value = 4100

[State -1, Raikiri]
type = ChangeState
Triggerall = power >= 2000
trigger1 = command = "holddown"
trigger1 = command = "b"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x >= 180 && enemy,pos y < -150
trigger2 = random < 100
value = 4125

[State -1, Kirin]
type = ChangeState
Triggerall = power >= 2500
trigger1 = command = "holddown"
trigger1 = command = "c"
trigger2 = RoundState = 2 && ailevel > 0 && P2BodyDist X = [30,250]
trigger2 = random < 150
value = 4150

[State -1, Susanoo Perfecto Puńo]
type = ChangeState
trigger1 = command = "a"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [0,150]
trigger2 = random < 40
trigger2 = enemy,pos y < -100
value = 4005

[State -1, Susanoo Perfecto Pisoton]
type = ChangeState
trigger1 = command = "b"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [40,120]
trigger2 = random < 40
trigger2 = enemy,pos y > -80
value = 4006

[State -1, Susanoo Perfecto Slash]
type = ChangeState
trigger1 = command = "c"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [100,150]
trigger2 = random < 40
value = 4007

[State -1, Susanoo LV3 Power Charge]
type = ChangeState
triggerall = power < 3000
trigger1 = command = "hold_y"
value = 500

[State -1, Susanoo LV3 Power Charge IA]
type = ChangeState
triggerall = RoundState = 2 && ailevel > 0
triggerall = power < 3000
triggerall = P2BodyDist X >= 150
trigger1 = power < 1000 && Random < 20
trigger2 = power < 2000 && power > 1000 && Random < 15
trigger3 = power < 3000 && power > 2000 && Random < 10
value = 500

[State 0, RemoveExplod] ;Power Charge
type = RemoveExplod
triggerall = prevstateno = 500
trigger1 = 1
id = 550

[State 0, StopSnd] ;Power Charge
type = StopSnd
triggerall = prevstateno = 500
trigger1 = 1
channel = 1

[State 0, StopSnd] ;Power Charge
type = StopSnd
triggerall = prevstateno = 500
trigger1 = 1
channel = 2

[State 200, End]
type = ChangeState
trigger1 = var(3) <= 0
trigger2 = win||lose||drawgame
value = 50
