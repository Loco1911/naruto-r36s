[Quotes]
victory0 = "En un mundo de desesperacion. No vale la pena que existas."
victory1 = "No soy nadie y tampoco quiero serlo..."
victory2 = "La paz verdadera no existe. Ni tampoco la esperanza!"
victory3 = "No hay esperanza. No hay luz. Solo hay desesperacion."
victory4 = "Ya perdiste cualquier esperanza. Solo te queda... dormir."
victory5 = "Soy unico, soy el segundo sabio de los seis caminos."
victory6 = "Yo controlo este mundo."
