value = S0,11
volume = 999
[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 20
value = S0,11
volume = 999

[State 0, Kunai 1]
type = Helper
trigger1 = time = 20
helpertype = normal
name = "Kunai 1"
ID = 8050
stateno = 8050
pos = 30,-48
postype = p1
facing = 1
keyctrl = 0
OwnPal = 1
Size.XSCale = 1
Size.YSCale = 1

[State 200, End]
type = ChangeState
Triggerall = power >= 200
triggerall = time >= 30
trigger1 = ailevel = 0 && command = "z"
trigger2 = ailevel > 0 && roundstate = 2 && random = [600,800]
value = 8001

[State 200, Run + Run IA]
type = ChangeState
triggerall = time >= 40
trigger1 = ailevel = 0 && command = "FF"
trigger2 = ailevel > 0 && random < (ailevel * 100)
value = 60

[State 200, End]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1

