;Perfume Spray (Particle)
[StateDef 1150]
type = A
movetype = I
physics = N
anim = 34971
velset = 4,0
sprpriority = 5

[State 1401, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 1401, Trans]
type = Trans
trigger1 = time < 30
trans = add
ignorehitpause = 1

[State 1401, Trans]
type = Trans
trigger1 = time >= 30
trans = addalpha
alpha = 256-(10*(time-30)), 256

[State 1401, VelSet]
type = VelSet
trigger1 = time = 5
x = 8+(.1*(random%10))
y = (-.5+(2*(NumHelper(1401)%2)))-(.05*(random%60))

[State 1401, AngleDraw]
type = AngleDraw
trigger1 = 1
scale = time*.05, time*.05
ignorehitpause = 1

[State 1401, StateTypeSet]
type = StateTypeSet
trigger1 = time = [5,33]
movetype = A

[State 1401, StateTypeSet]
type = StateTypeSet
trigger1 = time > 33
movetype = I

[State 1401, HitDef]
type = HitDef
trigger1 = !time
attr = A,HA        ;SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
Hitflag = MAFDE
guardflag = MA         ;HLA
animtype = hard          ;light,medium,hard,back,up,diagup
air.animtype = hard
damage = 3,0
pausetime = 0,5
sparkno = -1
guard.sparkno = -1
sparkxy = -10,-38
hitsound = -1
guardsound = -1
ground.type = High      ;Low,Trip,None
ground.slidetime = 11
ground.hittime = 11
air.hittime = 20
ground.velocity = -.2,0
air.velocity = -.2,-1
sprpriority = 1
fall = 0
air.fall = 1
hitonce = 0
kill = 1
numhits = 1
palfx.time = 10
palfx.add = 50,-50,0
palfx.mul = 256,256,256
palfx.sinadd = 40,40,40,10
palfx.invertall = 0
palfx.color = 256
getpower = 0,0

[State 0, Veneno en P2]
type = Helper
triggerall = numhelper(1275) = 0
Triggerall = p2movetype = H && p2stateno != [120,155]
trigger1 =  movehit = 1
triggerall = enemy, name != "Hanzo"
helpertype = normal
name = "Veneno en P2"
ID = 1275
