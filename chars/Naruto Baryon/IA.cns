triggerall = p2movetype = H
triggerall = numhelper(615) = 0
trigger1 = p2stateno = 614
helpertype = normal
name = "Boquete Pared"
ID =  615
stateno = 615
pos = 0,0
postype = p2
facing = -1
ownpal = 1
size.xscale = .8
size.yscale = .8
;-------------------------------------------------------------------------------
; Limitador Air Jump:
;-------------------------------------------------------------------------------
[State 0, VarSet]
type = VarSet
trigger1 = var(5) = 0 && (stateno = 65||stateno = 70)
v = 5
value = 1

[State 0, VarSet]
type = VarSet
trigger1 = var(5) = 1 && pos y >= 0
v = 5
value = 0

;-------------------------------------------------------------------------------
; Sonidos Comunes:
;-------------------------------------------------------------------------------
[State 0, Andando]
type = PlaySnd
triggerall = var(4) = 0
triggerall = stateno = 20
trigger1 = animelem = 3||animelem = 7
value = S20,1
[State 0, Andando]
type = PlaySnd
triggerall = var(4) = 0
triggerall = stateno = 20
trigger1 = animelem = 3||animelem = 7
value = S20,1

[State 0, Saltando]
type = PlaySnd
triggerall = var(4)= 0
triggerall = stateno = 40||stateno = 65
trigger1 = Time = 1
value = S40,1
volume = 55
channel = -1

[State 0, Super Jump]
type = PlaySnd
triggerall = stateno = 80
trigger1 = Time = 1
value = S60,1
volume = 55
channel = -1

[State 0, Land]
type = PlaySnd
triggerall = stateno = 52
trigger1 = time = 1
value = S52,1
volume = 50

[State 0, Run]
type = PlaySnd
triggerall = stateno = 60
trigger1 = time = 1
value = S40,3
volume = 50

[State 0, Run]
type = PlaySnd
triggerall = stateno = 70
trigger1 = time = 1
value = S40,1
volume = 50

[State 0, RemoveExplod]
type = RemoveExplod
TRIGGERALL = stateno != 500
trigger1 = time = 1
id = 550

[State 0, RemoveExplod]
type = RemoveExplod
TRIGGERALL = stateno = 500
trigger1 = time > 7
id = 1

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 1

[State 0, StopSnd]
type = StopSnd
TRIGGERALL = stateno != 500
trigger1 = time = 1
channel = 2

[State 0, Golpeado]
type = PlaySnd
Triggerall = NumHelper(860)= 0
Triggerall = NumHelper(90000)= 0
trigger1 = movetype=H && (stateno!=[0,155]) && !time && HitOver=0 && random%4=0
value = 5000,ifelse(random < 500,1,ifelse(random < 500,2,3))

[State 0, Solucion Stand Aire]
type = ChangeState
triggerall = stateno = 0||stateno = 20
trigger1 = pos y < 0
value = 50
ctrl = 1
[Statedef -4]

;This controller plays a sound everytime the player lands from a jump, or
;from a back-dash.
[State -3, Landing Sound]
type = PlaySnd
triggerall = Time = 1
trigger1 = stateno = 52 ;Jump land
trigger2 = stateno = 106 ;Run-back land
value = 0, 1

[State 0, Run FWD]
type = PlaySnd
triggerall = stateno = 100
trigger1 = time = 1
value = S81,0
volume = 50

[State 0, VarAdd]
type = VarAdd
trigger1 = numhelper(758) = 1
v = 23    ;fv =
value = 1
;ignorehitpause =
;persistent =

