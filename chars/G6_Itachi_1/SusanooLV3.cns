;===================================================================================
;---------------- Susanoo LV3 --------------------------------------------
;===============================================================================
; Susanoo Stand:
;-------------------------------------------------------------------------------
[Statedef 2000]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 0
sprpriority = 2

[State 0, Andando]
type = PlaySnd
triggerall = anim = 20 || anim = 21
trigger1 = animelem = 3||animelem = 6
value = S20,1

[State 0, NotHitBy]
type = NotHitBy
trigger1 =  1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 10

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -40

[State 0, Walk]
type = VelSet
trigger1 = command = "holdfwd" || command = "holdback"
x = ifelse(command = "holdfwd",2,-2)

[State 0, Walk FWD]
type = ChangeAnim
triggerall = anim != 20
trigger1 = vel x > 0
value = 20

[State 0, Walk Back]
type = ChangeAnim
triggerall = anim != 21
trigger1 = vel x < 0
value = 21

[State 0, Walk]
type = ChangeAnim
triggerall = anim = 20 || anim = 21
trigger1 = vel x = 0
value = 0

[State 0, Walk IA]
type = VelSet
trigger1 = RoundState = 2 && ailevel > 0 && p2bodydist x >= 100
trigger1 = random < 30
x = 2

[State 0, Walk IA]
type = VelSet
trigger1 = RoundState = 2 && ailevel > 0 && p2bodydist x > 50 && vel x > 0
trigger1 = 1
x = 2

[State -1, SPECIAL 1]
type = ChangeState
Triggerall = power >= 1000
Triggerall = numhelper(1150) = 0
trigger1 = command = "SPECIAL 1"
trigger2 = RoundState = 2 && ailevel > 0 && P2BodyDist X >= 100
trigger2 = random < 50
value = 1100

[State -1, SPECIAL 2]
type = ChangeState
Triggerall = power >= 1000
trigger1 = command = "SPECIAL 2"
trigger2 = RoundState = 2 && ailevel > 0 && P2BodyDist X <= 150
trigger2 = random < 50
value = 1300

[State -1, SPECIAL 3]
type = ChangeState
Triggerall = power >= 2000
trigger1 = command = "SPECIAL 3"
trigger2 = RoundState = 2 && ailevel > 0 && P2BodyDist X >= 100
trigger2 = random < 100
value = 3000

[State -1, SPECIAL 4]
type = ChangeState
Triggerall = power >= 1000
trigger1 = command = "SPECIAL 4"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [-50,50]
trigger2 = random < 50
value = 1980

[State -1, SPECIAL 5]
type = ChangeState
Triggerall = power >= 1000
trigger1 = command = "SPECIAL 5"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [100,200]
trigger2 = random < 50
value = 1700

[State -1, SPECIAL 6]
type = ChangeState
Triggerall = numhelper(15000) = 0
Triggerall = power >= 1000
trigger1 = command = "SPECIAL 6"
trigger2 = RoundState = 2 && ailevel > 0 && P2BodyDist X >= 100
trigger2 = random < 50
value = 1000

[State -1, Susanoo LV3 Slash 1]
type = ChangeState
trigger1 = command = "a"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [0,150]
trigger2 = random < 40
value = 2005

[State -1, Susanoo LV3 Slash 2]
type = ChangeState
trigger1 = command = "b"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [100,150]
trigger2 = random < 40
value = 2006

[State -1, Susanoo LV3 Slash 3]
type = ChangeState
trigger1 = command = "c"
trigger2 = RoundState = 2 && ailevel > 0 && p2bodydist x = [120,150]
trigger2 = random < 40
value = 2007

[State -1, Susanoo LV3 Power Charge]
type = ChangeState
triggerall = power < 3000
triggerall = command != "holddown"
trigger1 = command = "hold_y"
value = 500

[State -1, Susanoo LV3 Power Charge IA]
type = ChangeState
triggerall = RoundState = 2 && ailevel > 0
triggerall = power < 3000
triggerall = P2BodyDist X >= 150
trigger1 = power < 1000 && Random < 20
trigger2 = power < 2000 && power > 1000 && Random < 15
trigger3 = power < 3000 && power > 2000 && Random < 10
value = 500

[State 0, RemoveExplod] ;Power Charge
type = RemoveExplod
triggerall = prevstateno = 500
trigger1 = 1
id = 550

[State 0, StopSnd] ;Power Charge
type = StopSnd
triggerall = prevstateno = 500
trigger1 = 1
channel = 1

[State 0, StopSnd] ;Power Charge
type = StopSnd
triggerall = prevstateno = 500
trigger1 = 1
channel = 2

[State 200, End]
type = ChangeState
trigger1 = var(3) <= 0
trigger2 = win||lose||drawgame
value = 554
;-------------------------------------------------------------------------------
; Susanoo Slash 1
[Statedef 2005]
type    = S
movetype= A
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 215
sprpriority = 2

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S0,ifelse(random < 500,14,ifelse(random < 500,17,16))
volume = 999

[State 0, NotHitBy]
type = NotHitBy
trigger1 =  1
value = SCA,NA,SA,HA,NP,SP,HP,NT,ST,HT
time = 10

[State 0, ChangeAnim]
type = ChangeAnim
triggerall = time >= 8
trigger1 = helper(2050),time < 71
value = 215
elem = 3

[State 0, ChangeAnim]
type = ChangeAnim
trigger1 = helper(2050),time = 71
value = 215
elem = 4

[State 200, End]
type = ChangeState
trigger1 = time = 76
value = 2000
