[Statedef 2050]
type    = S
movetype= I
physics = N
juggle  = 1
velset = 0,0
ctrl = 0
anim = 2050
sprpriority = 3

[State 0, Negro]
type = Helper
trigger1 = numhelper(2460) = 0
helpertype = normal
name = "Negro"
ID = 2460
stateno = 2460
pos = 0,0
postype = p1
facing = 1
keyctrl = 0
ownpal = 1

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 0, PosAdd]
type = Posset
triggerall = root,facing = 1
trigger1 = 1
x = root,pos x-60

[State 0, PosAdd]
type = Posset
triggerall = root,facing = -1
trigger1 = 1
x = root,pos x+60

[State 0, PosSet]
type = Posset
trigger1 = 1
y = 5

[State 0, Trans]
type = Trans
trigger1 = 1
trans = add
ignorehitpause = 1

[State 0, AssertSpecial]
type = AssertSpecial
trigger1 = 1
flag = noshadow
ignorehitpause = 1

[State 0, VelSet]
type = VelSet
trigger1 = !time
x = 0
y = 0

[State 0, Susanoo Amaterasu]
type = ChangeState
trigger1 = root,stateno = 2100
value = 2200

[State 0, Yasaka no Magatama]
type = ChangeState
trigger1 = root,stateno = 2125
value = 2300

[State 0, Slash 1]
type = ChangeState
trigger1 = root,stateno = 2005
value = 2055

[State 0, Slash 2]
type = ChangeState
trigger1 = root,stateno = 2006
value = 2056

[State 0, Slash 3]
type = ChangeState
trigger1 = root,stateno = 2007
value = 2057

[State 0]
type = AssertSpecial
trigger1 = root,stateno = 3200
flag = invisible

[State 200, End]
type = Destroyself
trigger1 = root,var(4) = 0
