walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "No tuviste oportunidad contra mi..."
victory1 = "La guerra causa muertes... heridas y dolor para ambos bandos..."
victory2 = "No olvides... este dolor!"
victory3 = "Yahiko, Konan... guienme..."
