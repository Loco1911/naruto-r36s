; Gamaken - Stand
[Statedef 3401]
type = S
physics = S
sprpriority = -1
anim = 3450

[State 0, Helper Tiempo]
type = Helper
trigger1 = prevstateno = 3400 && time = 0
helpertype = normal
name = "Helper Tiempo"
ID = 33100
stateno = 33100
pos = 0,0
postype = p1

[State 0, Turn]
type = Turn
triggerall = parent,var(18) = 1 && parent,stateno = 3001
trigger1 = p2bodydist x < -50

[State 0, Turn]
type = Turn
triggerall = parent,var(18) = 0
trigger1 = p2bodydist x < -50

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3]
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0

; Jiraiya Controlando:

[State 0, Walk FWD]
type = ChangeState
Triggerall = parent,var(18) = 1 && parent,stateno != 504
triggerall = time >= 5
Triggerall = parent,var(18) = 1 && parent,stateno = 3001
Trigger1 = parent,command = "holdfwd"
value = 3420

[State 0, Walk Back]
type = ChangeState
triggerall = time >= 5
Triggerall = parent,var(18) = 1 && parent,stateno = 3001
Trigger1 = parent,command = "holdback"
value = 3421

;-----------------------
[State 0, ChangeState]
type = Changestate
trigger1 = parent,var(19) <= 0
trigger2 = parent,win
trigger3 = parent,drawgame
trigger4 = parent,lose
trigger5 = parent,var(2) = 1
trigger6 = numhelper(33100) = 0
value = 3402
