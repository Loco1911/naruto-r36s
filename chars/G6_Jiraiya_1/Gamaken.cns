;---------------------------------------
; Walk FWD
;--------------------------------------
[Statedef 3420]
type    = S
physics = S
sprpriority = -1

[State 0, Walk Stop Powercharge]
type = ChangeState
Triggerall = parent,var(18) = 1 && parent,stateno = 504
trigger1 = 1
value = 3401

[State 20, 1]
type = VelSet
trigger1 = parent,var(18) = 0
trigger2 = parent,var(18) = 1 && parent,var(9) = 0 && parent,command = "holdfwd"
trigger3 = parent,var(18) = 1 && parent,var(9) = 1
x = const(velocity.walk.fwd.x)-1

[State 20, 3]
type = ChangeAnim
triggerall = parent,var(18) = 1
triggerall = vel x > 0
trigger1 = (Anim != 3460 && Anim != 5)
trigger2 = (Anim = 5) && AnimTime = 0
value = 3460

[State 20, 3]
type = ChangeAnim
triggerall = parent,var(18) = 0
triggerall = vel x > 0
trigger1 = (Anim != 34600 && Anim != 5)
trigger2 = (Anim = 5) && AnimTime = 0
value = 34600

[State 0, PlaySnd]
type = PlaySnd
trigger1 = animelem = 2
value = S20,3

; Jiraiya Controlando:

[State 0, Walk Back]
type = ChangeState
triggerall = parent,var(18) = 1 && parent,var(9) = 0
triggerall = time >= 5
trigger1 = command = "holdback"
value = 3421

[State 0, ChangeState]
type = ChangeState
trigger1 = parent,var(18) = 0 && p2bodydist x < 150
trigger2 = parent,var(18) = 1 && parent,var(9) = 0 && parent,command != "holdfwd"
trigger3 = parent,var(18) = 1 && parent,var(9) = 1 && p2bodydist x < 150
value = 3401
