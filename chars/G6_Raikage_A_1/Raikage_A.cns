yscale = 1.05
ground.back = 13
ground.front = 13
air.back = 13
air.front = 13
height = 55
attack.dist = 160
proj.attack.dist = 90
proj.doscale = 0
head.pos = -5, -55
mid.pos = -5, -25
shadowoffset = 0
draw.offset = 0,0

[Velocity]
walk.fwd  = 4
walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Mi mano de lanza infernal puede penetrar cualquier cosa."
victory1 = "Mi mano es la lanza más fuerte de todas!"
victory2 = "Nadie puede detenerme!"
victory3 = "Soy el único y más grande ninja en todos los cielos y la tierra."
victory4 = "El titulo de Raikage no se demuestra solo con palabras."
