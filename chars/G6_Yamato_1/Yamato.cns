walk.back = -4
run.fwd  = 0
run.back = 0
jump.neu = 0,-9
jump.back = -4
jump.fwd = 4
runjump.back = 0
runjump.fwd = 0
airjump.neu = 0
airjump.back = 0
airjump.fwd = 0

[Movement]
airjump.num = 0
airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Llevo el estilo de madera y la Voluntad de fuego en mi interior!"
victory1 = "Si crees que soy un buen tipo, te equivocaste conmigo."
victory2 = "Que te parecio mi estilo de madera?"
victory3 = "No subestimes la voluntad de fuego."
