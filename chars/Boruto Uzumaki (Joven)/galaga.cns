;; Galaga - Stand
[Statedef 60000]
type = S
physics = S
sprpriority = 0
[State 200, Eliminar]
type = ChangeState
trigger1 = root,fvar(30) = 0
trigger2 = win
trigger3 = parent,life = 0
trigger3 = drawgame
trigger4 = lose
value = 60001
[State 0, ScreenBound]
type = ScreenBound
trigger1 = 1
value = 0

[State 0, Turn]
type = Turn
trigger1 = p2bodydist x < -25

[State 0, 1]
type = ChangeAnim
trigger1 = (Anim != 0 && Anim != 60055 && Anim != 60000 && Anim != 60055 && Anim != 17000 && Anim != 17005 && Anim != 19000 && Anim != 19005)
trigger2 = (Anim = 60055||Anim = 15005||Anim = 17005||Anim = 19005) && AnimTime = 0
value = 60000

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3]
type = VelSet
trigger1 = abs(vel x) < 2
trigger2 = Time = 4
x = 0
[State -1, Golpe 1]
type = changestate
triggerall = StateType = S
triggerall = (p2statetype = S) || (p2statetype = C)|| (p2statetype = A)
triggerall = P2BodyDist X >= 200
triggerall = P2BodyDist X <= 500
trigger1 = Random =[500,600]
value = 60200
[State -1, Golpe 1]
type = changestate
triggerall = StateType = S
triggerall = (p2statetype = S) || (p2statetype = C)|| (p2statetype = A)
triggerall = P2BodyDist X <= 500
trigger1 = Random =[500,600]
value = 60300

[State -1, Golpe 1]
type = changestate
triggerall = StateType = S
triggerall = (p2statetype = S) || (p2statetype = C)|| (p2statetype = A)
triggerall = P2BodyDist X >= 200
trigger1 = Random =[100,200]
value = 60003

