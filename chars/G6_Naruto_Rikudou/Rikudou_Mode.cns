triggerall = root,stateno = 61
trigger1 = 1
pos = 8,-45

[State 0, BindToRoot] ;RUN FWD Air
type = BindToRoot
triggerall = root,anim = 110
triggerall = root,stateno = 65
trigger1 = 1
pos = 8,-45

[State 0, BindToRoot] ;RUN FWD
type = BindToRoot
triggerall = root,stateno = 20600
trigger1 = root,time < 2
pos = 8,-65

[State 0, BindToRoot] ;RUN BACK
type = BindToRoot
triggerall = root,stateno = 20700
trigger1 = root,time < 2
pos = -12,-65

[State 0, AssertSpecial] ; RUN
type = AssertSpecial
triggerall = root,stateno = 20600||root,stateno = 20700
trigger1 = root,time = [2,7]
flag = invisible
flag2 = noshadow

[State 0, BindToRoot] ;RUN
type = BindToRoot
triggerall = root,stateno = 20600||root,stateno = 20700
trigger1 = root,time > 7
trigger1 = 1
pos = 2,-45

[State 0, SprPriority] ;RUN
type = SprPriority
triggerall = root,stateno = 20600||root,stateno = 20700
trigger1 = root,time > 7
value = -2

[State 0, BindToRoot] ;DASH
type = BindToRoot
triggerall = root,stateno = [8500,8505]
trigger1 = 1
pos = 2,-45

[State 0, BindToRoot] ; GUARD
type = BindToRoot
triggerall = root,stateno = [120,155]
trigger1 = 1
pos = 2,-55

[State 0, BindToRoot] ;HITTED
type = BindToRoot
triggerall = root,stateno != 5101
triggerall = root,stateno != 5100
triggerall = root,stateno != 5110
triggerall = root,stateno != 5035
triggerall = root,stateno != 5050
triggerall = root,stateno = [5000,5300]
trigger1 = 1
pos = 2,-55

[State 0, BindToRoot] ;HITTED
type = BindToRoot
