;===============================================================================
;---------------- Rikudou Mode -------------------------------------------------
;===============================================================================
;===============================================================================
; Gudodama FX:
;-------------------------------------------------------------------------------
[Statedef 8001]
type    = S
movetype= I
physics = S
juggle  = 1
velset = 0,0
ctrl = 0
anim = 2001
sprpriority = 0

[State 0, Turn]
type = Turn
trigger1 = facing != root,facing

[State 0, BindToRoot] ;STAND
type = BindToRoot
triggerall = root,stateno = 0
trigger1 = 1
pos = 2,-55

[State 0, BindToRoot] ;CROUCH
type = BindToRoot
triggerall = root,stateno = [10,12]
trigger1 = 1
pos = 2,-45

[State 0, BindToRoot] ;WALK  FWD
type = BindToRoot
triggerall = root,anim = 20
triggerall = root,stateno = 20
trigger1 = 1
pos = 8,-45

[State 0, BindToRoot] ;WALK BACK
type = BindToRoot
triggerall = root,anim = 21
triggerall = root,stateno = 20
trigger1 = 1
pos = -12,-45

[State 0, BindToRoot] ;JUMP START/END
type = BindToRoot
triggerall = root,stateno = 40||root,stateno = 52
trigger1 = 1
pos = 2,-45

[State 0, BindToRoot] ;JUMP
type = BindToRoot
triggerall = root,stateno = 50||root,stateno = 80||root,stateno = 51
trigger1 = 1
pos = 2,-65

[State 0, BindToRoot] ;JUMP
type = BindToRoot
triggerall = root,stateno = 70
trigger1 = 1
pos = 2,-55

[State 0, BindToRoot] ;RUN  FWD
type = BindToRoot
triggerall = root,anim = 100
triggerall = root,stateno = 60
trigger1 = 1
pos = 8,-45

[State 0, BindToRoot] ;RUN FWD
type = BindToRoot
