;---------------------------------------------------------------------------
; Insect Ball
[StateDef 1050]
Type = S
MoveType = I
Physics = N
Juggle = 1
Ctrl = 0
Anim = 1005
SprPriority = 2

[State 300, 1]
type = PlaySnd
trigger1 = time%30=0
value = S0,27
volume = 50

[State 0, Null]
Type = Null
Trigger1 = !Time
Trigger1 = Var(0) := 65
Trigger2 = Time && Var(0) > 15
Trigger2 = Var(0) := Var(0) -1
IgnoreHitPause = 1

[State 0, PosAdd]
Type = PosAdd
Trigger1 = Time <= 40
Y = -Ceil(1.0-((Time/40.0)*1.0))

[State 0, Explod]
Type = Explod
Trigger1 = Time <= 60
Anim = 2002
ID = 2002
Pos = Floor(Cos(Time/15.0*PI)*Var(0)), Floor(Sin(Time/15.0*PI)*Var(0))
PosType = P1
Facing = 1 - 2*(Random<500)
VFacing = 1 - 2*(Random<500)
BindTime = -1
RemoveTime = -2
SuperMoveTime = -1
PauseMoveTime = -1
Scale = .5,.5
SprPriority = 10
IgnoreHitPause = 1

[State 0, Explod]
Type = Explod
Trigger1 = Time >= 60 && FrontEdgeDist > 0
Anim = 2002
ID = 2002
Pos = -20+Random%41,-20+Random%41
PosType = P1
Facing = 1 - 2*(Random<500)
VFacing = 1 - 2*(Random<500)
BindTime = -1
RemoveTime = -2
SuperMoveTime = -1
PauseMoveTime = -1
Scale = .7,.7
SprPriority = 10
IgnoreHitPause = 1

[State 0, VelSet]
Type = VelSet
Trigger1 = Time = 60
X = 7
Y = 5

[State 0, VelMul]
Type = VelMul
Trigger1 = Pos Y >= - 50
Y = .7

[State 0, StateTypeSet]
Type = StateTypeSet
Trigger1 = Time >= 60 && Pos Y >= -50
MoveType = A

[State 0, HitOverRide]
Type = HitOverRide
Trigger1 = 1
Attr = SCA,AA,AP,AT
StateNO = 1006
Time = -1
IgnoreHitPause = 0

[State 0, HitBy]
Type = HitBy
Trigger1 = 1
Value = SCA,SP,HP
Time = -1
IgnoreHitPause = 1

[State 0, EnvShake]
Type = EnvShake
Trigger1 = !(Time%12)
Time = 12
Freq = 40
Ampl = 2
Phase = 80

[State 0, AttackMulSet]
Type = AttackMulSet
Trigger1 = NumTarget
Value = (0.9 ** (Target,GetHitVar(HitCount)))

[State 0, Explod]
Type = Explod
Trigger1 = !(Time%4) && Pos Y >= -50
Anim = 7012
ID = 7012
Pos = 0,-Floor(Pos Y)
PosType = P1
Facing = 1 - 2*(Vel X < 0)
BindTime = 1
RemoveTime = -2
SuperMoveTime = -1
PauseMoveTime = -1
Scale = .35,.35
SprPriority = 15

;------------------------
[State 0, AttackMulSet]
type = AttackMulSet
trigger1 = 1
value = 1+root,fvar(2)
[State 0, Pause]
type = Pause
triggerall = root,var(2) = 1
trigger1 = movehit = 1
time = 3
movetime = 0
[State 0, EnvShake]
type = EnvShake
triggerall = root,var(2) = 1
trigger1 = movehit = 1
time = 5
;------------------------

[State 200, 1]
type = HitDef
triggerall = hitcount < 6
trigger1 = timemod = 2,0
attr = A, SP
animtype  = medium
damage    = 25,15
Hitflag = MAFDE
guardflag = MA
pausetime = 5,4
sparkno = -1
guard.sparkno = s7000
sparkxy = 0,0
hitsound   = S1,16
guardsound = S4,1
ground.type = High
ground.slidetime = 12
ground.hittime  = 15
ground.velocity = -3,-1
air.velocity = -3,-3
Fall = 1
getpower = 0,0
envshake.time = 5
PalFx.Time = 20
PalFx.add = -255,-255,-255
PalFx.sinadd = 255,255,255,60

[State 0, TargetPowerAdd]
type = TargetPowerAdd
triggerall = parent,var(2) = 0
trigger1 = movehit = 1
value = -200

[State 0, TargetPowerAdd]
type = TargetPowerAdd
triggerall = parent,var(2) = 1
trigger1 = movehit = 1
value = -300

[State 200, Spark CVS]
type = Explod
triggerall = Numexplod(7001) = 0
triggerall = Movehit = 1
trigger1 = hitcount = 1||hitcount = 3||hitcount = 5
anim = 7016
ID = 7001
postype = P1
pos = 20,-5
facing = 1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = 0.4,0.4
removeongethit = 1
ontop = 1
supermovetime 	= 999
ignorehitpause  = 1
[State 200, Spark CVS]
type = Explod
triggerall = Numexplod(70014) = 0
triggerall = Movehit = 1
trigger1 = hitcount = 2||hitcount = 4||hitcount = 6
anim = 7016
ID = 70014
postype = P1
pos = 20,-5
facing = 1
sprpriority = 2
supermove = 1
removetime = -2
bindtime = 1
ownpal = 1
scale = 0.4,0.4
removeongethit = 1
ontop = 1
supermovetime 	= 999
ignorehitpause  = 1

[State 0, DestroySelf]
Type = DestroySelf
trigger1 = frontedgebodydist <= -50
trigger2 = hitcount >= 6
trigger3 = moveguarded
