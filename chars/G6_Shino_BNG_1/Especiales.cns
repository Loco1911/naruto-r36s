Trigger1 = NumTarget
Trigger1 = AnimElemTime(2)>=0&&AnimElemTime(3)<0
Trigger1 = Time%5=0
Trigger2 = NumTarget
Trigger2 = !AnimElemTime(3)
Value = 1

[State 0, TargetState]
