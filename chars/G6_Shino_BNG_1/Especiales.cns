Trigger1 = NumTarget && !AnimElemTime(4)
Value = 803

[State 0, StateTypeSet]
Type = SprPriority
Trigger1 = AnimElemTime(3) >= 0
Value = -1
IgnoreHitPause = 1

[State 0, Explod]
