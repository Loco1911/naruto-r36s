; P2's Custom State
[StateDef 28060]
Type = S
MoveType = H
Physics = N
SprPriority = -1
Ctrl = 0

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Trigger1 = GetHitVar(AnimType) != [3,5]
Value = Cond((GetHitVar(GroundType) = 1),5000,5010) + GetHitVar(AnimType)

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Trigger1 = GetHitVar(AnimType) = [3,5]
Value = 5030+var(11)

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Trigger1 = (GetHitVar(AnimType) = [4,5]) && (SelfAnimExist(5047 + GetHitVar(AnimType)))
Value = 5047 + GetHitVar(AnimType)
Elem = 1

[State 0, LifeAdd]
Type = LifeAdd
Trigger1 = !(Time%10)
Value = -6
Kill = 0

[State 0, PowerAdd]
type = PowerAdd
triggerall = var(2) = 1
Trigger1 = !(Time%10)
value = -110

[State 0, PalFX]
Type = PalFX
Trigger1 = !(Time%10)
Time = 4
Add = -56,-128,7
Mul = 256,256,256
SinAdd = 56,56,0,16
InvertAll = 0
Color = 0

[State 0, VelSet]
Type = VelSet
Trigger1 = !(Time%2)
X = Cond(Vel X <= 0, 0.85,-0.85)

[State 0, NotHitBy]
type = NotHitBy
Trigger1 = 1
Value = SCA
Time = 10

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !HitShakeOver
Value = Anim

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = HitShakeOver && SelfAnimExist(5300)
Value = 5300+var(11)
Persistent = 0

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = HitShakeOver && !SelfAnimExist(5300)
Value = 5000+var(11)
Persistent = 0

[state 0, HitFallSet]
Type = HitFallSet
Trigger1 = !Time
Value = 1

[State 0, ScreenBound]
Type = ScreenBound
Trigger1 = 1
Value = 1
MoveCamera = 1,0

[State 0, PlayerPush]
Type = PlayerPush
Trigger1 = 1
Value = 0
IgnoreHitPause = 1

[State 0, SelfState]
Type = SelfState
Trigger1 = !GetHitVar(IsBound)
Trigger1 = Time > 200
Value = 5050
