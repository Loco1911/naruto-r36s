;-------------------------------------------------------------------------------
; Wall Hit - Slow
[StateDef 900]
Type = A
MoveType = I
Physics = N
SprPriority = -1
Ctrl = 0

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Trigger1 = GetHitVar(AnimType) != [3,5]
Value = Cond((GetHitVar(GroundType) = 1),5000,5010) + GetHitVar(AnimType)

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Trigger1 = GetHitVar(AnimType) = [3,5]
Value = 5030

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !Time
Trigger1 = (GetHitVar(AnimType) = [4,5]) && (SelfAnimExist(5047 + GetHitVar(AnimType)))
Value = 5047 + GetHitVar(AnimType)
Elem = 1

[State 0, LifeAdd]
Type = LifeAdd
Trigger1 = !Time
Value = -GetHitVar(Damage)

[State 0, ChangeAnim]
Type = ChangeAnim
Trigger1 = !HitShakeOver
Value = Anim

[State 0, ChangeAnim2]
Type = ChangeAnim2
Trigger1 = HitShakeOver
Value = 900
Persistent = 0

[state 0, HitFallSet]
Type = HitFallSet
Trigger1 = !Time
Value = 1

[State 0, ScreenBound]
Type = ScreenBound
Trigger1 = 1
Value = 1
MoveCamera = 1,0

[State 0, PlayerPush]
Type = PlayerPush
Trigger1 = 1
Value = 0
IgnoreHitPause = 1

[State 0, VelSet]
Type = VelSet
Trigger1 = HitShakeOver
X = -10
Y = -5
Persistent = 0

[State 0, VelAdd]
Type = VelAdd
Trigger1 = HitShakeOver
Y = 0.3

[State 0, EnvShake]
Type = EnvShake
Trigger1 = HitShakeOver && BackEdgeBodyDist <= 0
Trigger2 = (Pos Y + Vel Y) > 0
Time = 10
Ampl = 10

[State 0, SelfState]
Type = SelfState
Trigger1 = !GetHitVar(IsBound)
Trigger1 = Time > 200
Value = 5050

[State 0, SelfState]
Type = SelfState
Trigger1 = (Pos Y + Vel Y) > 0
Value = 5100

[State 0, ChangeState]
Type = ChangeState
Trigger1 = HitShakeOver && BackEdgeBodyDist <= 0
Value = 904
Ctrl = 0

