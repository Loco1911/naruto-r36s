; Chakra Ball - Start
[Statedef 2721]
type = S
movetype = A
physics = S
anim = 6300
sprpriority = 10
velset = 0,-.4
ctrl = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = !time
value = S0,45
volume = 255
channel = -1
freqmul = .7

[State 0, AngleDraw]
type = AngleDraw
trigger1 = 1
scale = (time/60.00)+sin(time)/6.00,(time/60.00)+sin(time)/6.00

[State 0, DestroySelf]
type = DestroySelf
trigger1 = parent,stateno != 3498

