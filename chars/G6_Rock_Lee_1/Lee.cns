airjump.height = 35
yaccel = .44
stand.friction = .85
crouch.friction = .82

[Quotes]
victory0 = "Si no crees en ti mismo, nunca me venceras."
victory1 = "Ahora me toca a mi emprender mi camino ninja!"
victory2 = "Nunca perdere por muy fuerte que sea mi adversario."
victory3 = "El esfuerzo hace que la victoria sepa mejor!"
victory4 = "El trabajo duro derrota el talento narutal."
