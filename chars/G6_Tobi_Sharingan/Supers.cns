random = 400,400
ontop = 1
ignorehitpause=1

[State 0]
type = Trans
trigger1 = time >= 100
trans = addalpha
alpha = 256-(10*(time-100)), 256

[State 0]
type = DestroySelf
trigger1 = animtime = 0




