;Stage: Jiraiya's Forest            -            feito por/by: DG & his son
; *e-mail:
;  .info@dgmugen.com.br 
; *site:
;  .https://dgmugen.com.br
; some part of the stage were fixed by OldGamer

;--------------------------------------------------------
[Info]
name         = "Jiraiya's Forest"	; Name of the stage.
displayname  = "Jiraiya's Forest"	; Name to display
versiondate  = 1.1		; Version date of stage (MM,DD,YYYY or X.XX)
mugenversion = 1.1		; Version of M.U.G.E.N stage works on (X.XX)
author       = "DG Mugen"	; Stage author name

;--------------------------------------------------------
[Camera]
startx = 0
starty = 0
boundleft = -80 
boundright = 90
boundhigh = -90 ;-90
boundlow = 0
tension = 50 
tensionhigh = 130 
tensionlow = 30 
overdrawhigh = 150
verticalfollow = .2
overdrawlow = 10
startzoom = 1,1
zoomin = .9 
zoomout = .7 

;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -130 ;-70        
p1starty = 0            
p1startz = 0            
p1facing = 1            

;--- Player 2 ---
p2startx = 130 ;70
p2starty = 0
p1startz = 0
p2facing = -1

;--- Player 3 ---
p3startx = -230
p3starty = 0
p3facing = 1

;--- Player 4 ---
p4startx = 230
p4starty = 0
p4facing = -1

;--- Common ---
leftbound  = -4000 ;Left bound (x-movement)
rightbound =  4000 ;Right bound
;--------------------------------------------------------
[Scaling]
topz     = 0       ;Top z-coordinate for scaling
botz     = 50      ;Bottom z-coordinate for scaling
topscale = 1       ;Scale to use at top
botscale = 1.2     ;Scale to use at bottom

;--------------------------------------------------------
[Bound]
;Distance from left/right edge of screen that player can move to
;Typically 15
screenleft = 15    ;Dist from left of screen that player can move to
screenright = 15   ;Right edge

;--------------------------------------------------------
[StageInfo]
zoffset = 440 
resetBG = 1
autoturn = 1
localcoord = 640, 480 ;320, 240
xscale = 1
yscale = 1

;--------------------------------------------------------
[Shadow]
intensity = 64
color = 0,0,0
yscale = -1
fade.range = -400,-100

;--------------------------------------------------------
[Reflection]
intensity = 0 ;128

;--------------------------------------------------------
[Music]
bgmusic = sound/naruto-jiraiyas-theme.mp3
bgmvolume = 100

;-------------------------------------
; Main background definition
[BGdef]
spr = jiraiyasforest_dg.sff
debugbg = 0

;--------------------------------------

[BG White BG]
type = Normal
spriteno = 0, 10
mask = 1
start = 0, 0
scalestart = 1,1
delta = 0.0001, 0.0001

;--------------------------------------

[BG Layer 5] ;backgrund grass
type = Normal
spriteno = 0, 5
mask = 1
start = 0, -230
scalestart = .3,.3
delta = .32, .35 ;.28, .31

;--------------------------------------

[BG Layer 5] ;bg tree 
type = anim ;Normal
id = 1
actionno = 1
;spriteno = 0, 6
mask = 1
start = 0, -230
scalestart = .3,.3
delta = .25, .28

;--------------------------------------

;[BG Layer 4] ;fog
;type = anim ;Normal
;id = 3
;actionno = 3
;;spriteno = 0, 9
;mask = 1
;start = 0, -230
;tile  = 1,0
;tilespacing = 3508
;scalestart = .3,.3
;delta = .45, .40 ;.32, .40

;--------------------------------------

[BG Layer 4] ;back grass
type = anim ;Normal
id = 2
actionno = 2
;spriteno = 0, 3
mask = 1
start = 0, -230
scalestart = .3,.3
delta = .45, .40 ;.32, .40

;--------------------------------------

[BG Layer 3] ;top trees
type = Normal
spriteno = 0, 2
mask = 1
start = 0, -230
scalestart = .3,.3
delta = .55, .5 ;.5, .50 ;.43, .60

;--------------------------------------

[BG Layer 2] ;floor grass
type = Normal
spriteno = 0, 1
mask = 1
start = 0, -230
scalestart = .3,.3
delta = .75, .65 ;.45, .63
xscale = -.4, 1.980 

;--------------------------------------

[BG Layer 1] ;front grass
type = Normal
spriteno = 0, 0
mask = 1
start = 0, -230
scalestart = .3,.3
delta = .85, 1 ;.5, 1
layerno = 1

;--------------------------------------



