;_________________________________________________________
;INFORMACJE
;_________________________________________________________
[Info]
name ="Akatsuki Stage"
author= "Shinrashi" converted to directx by Mugen Gamer
;_________________________________________________________
;PARAMETRY
;_________________________________________________________
[Camera]
startx = 0
starty = 0
boundleft = -50
boundright = 320
boundhigh = -320
boundlow = 0
verticalfollow = .85
floortension = 200
tension = 200
tensionhigh = 20
tensionlow = 400
zoomin = .45
zoomout = .3
[PlayerInfo]
p1startx = -450        
p1starty = 0           
p1facing = 1           
p2startx = 450
p2starty = 0
p2facing = -1
p3startx = -350
p3starty = 0
p3facing = 1
p4startx = 350
p4starty = 0
p4facing = -1
leftbound  = -3000
rightbound =  3000
[Bound]
screenleft = 80
screenright = 80
[StageInfo]
zoffset = 630
autoturn = 1
resetBG = 1
localcoord = 1280, 720
xscale = 2
yscale = 2
[Shadow]
intensity = 40
color = 0,0,0
yscale = .1
fade.range = 0,0
[Reflection]
intensity = 0
;--------------------------------------------------------
[Music]
bgmusic = sound/Akatsuki.mp3
bgmvolume = 100
;-------------------------------------
[BGdef]
spr = Akatsuki Stage.sff
debugbg = 0
