;STAGE:
;--------------------------------------------------------
[Info]
 ;Nombre del escenario:
name = "Campo de Entrenamiento (Tarde)"
;--------------------------------------------------------
[Camera]
; Cßmara posici¾n inicial: Por lo general 0 para ambos
startx = 0
starty = 0
boundleft = -360
boundright = 360
boundhigh = -40
boundlow = 20
verticalfollow = 1
floortension =100
tension = 100
tensionhigh = 120
tensionlow = 80
cuthigh 	= 5
cutlow 		= 5
zoomin = .85
zoomout = .60
;------------------------------------------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -100          
p1starty = 0            
p1startz = 0            
p1facing = 1            
