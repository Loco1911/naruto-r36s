;--- Player 3 ---
p3startx = -65
p3starty = 0
p3startz = 0
p3facing = 1
 ;------------------------------------------------------------------------------------------
;--- Player 4 ---
p4startx = 65
p4starty = 0
p4startz = 0
p4facing = -1
 ;------------------------------------------------------------------------------------------
;--- Common ---
leftbound  = -1000 
rightbound =  1000 
topbound  =  0     
botbound  =  0
;------------------------------------------------------------------------------------------
[Scaling]
topz     = 0       
botz     = 50      
topscale = 1       
botscale = 1.2
;------------------------------------------------------------------------------------------
[Bound]
screenleft = 30  
screenright = 30 
;------------------------------------------------------------------------------------------
[StageInfo]
zoffset = 220
autoturn = 1
resetBG = 1
hires = 1
xscale = .5
yscale = .5
;--------------------------------------------------------
[Shadow]
intensity = 120
color = 0,0,0
yscale = .4
fade.range = 0,0
;--------------------------------------------------------
[Reflection]
;DEL 0 AL 256
intensity = 0
;--------------------------------------------------------
[Music]
bgmusic  =sound/Campo_de_Entrenamiento.mp3
bgvolume = 255
;========================================================
;-------------------------------------
; Main background definition
[BGdef]
 ;Sprites:
spr = Campo de Entrenamiento (Tarde).sff
debugbg = 0

