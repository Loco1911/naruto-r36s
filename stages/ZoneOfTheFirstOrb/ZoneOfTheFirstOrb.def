interpolate blend
3,2, 0,0, 30,,AS256D256,1,1,0                  
interpolate blend
3,2, 0,0, 40,,AS128D256,1,1,0                    
interpolate blend
3,2, 0,0, 78,,AS0D256,1,1,0                   
interpolate blend
3,2, 0,0, 45,,AS256D256,1,1,0                   
interpolate blend
3,2, 0,0, 28,,AS0D256,1,1,0                   
interpolate blend
3,2, 0,0, 16,,AS196D256,1,1,0
interpolate blend
3,2, 0,0, 24,,AS128D256,1,1,0                    
interpolate blend
3,2, 0,0, 35,,AS0D256,1,1,0

; lens 1
[Begin Action 2]             
interpolate blend
4,0, 0,0, 210,,AS256D256,1,1,0                  
interpolate blend
4,0, 0,0, 240,,AS196D256,1,1,0                    
interpolate blend
4,0, 0,0, 150,,AS256D256,1,1,0                   
interpolate blend
4,0, 0,0, 100,,AS256D256,1,1,0                   
interpolate blend
4,0, 0,0, 70,,AS64D256,1,1,0                   
interpolate blend
4,0, 0,0, 90,,AS196D256,1,1,0
