;--------------------------------------------------------
; Anims:

; Orb Anim 1
[Begin Action 0]             
interpolate blend
3,1, 0,0, 80,,AS256D256,1,1,0                  
interpolate blend
3,1, 0,0, 120,,AS128D256,1,1,0                    
interpolate blend
3,1, 0,0, 150,,AS0D256,1,1,0                   
interpolate blend
3,1, 0,0, 80,,AS256D256,1,1,0                   
interpolate blend
3,1, 0,0, 20,,AS0D256,1,1,0                   
interpolate blend
3,1, 0,0, 80,,AS196D256,1,1,0
interpolate blend
3,1, 0,0, 40,,AS128D256,1,1,0                    
interpolate blend
3,1, 0,0, 120,,AS0D256,1,1,0
   
;  Orb Anim 2
