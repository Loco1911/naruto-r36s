;--------------------------------------------------------
[Info]
name = "Uchiha Hideout Light"
displayname = "Uchiha Hideout-Light"
versiondate = 25,07,2024
mugenversion = 1.1
author = "Vogel" and Edit/Convert to DirectX by Crescent Mugen (CM)
;--------------------------------------------------------
[Camera]
startx =0
starty =0
boundleft=-760
boundright= 760
boundhigh= -200
boundlow =0
verticalfollow = 1.2
floortension = 100
tension = 200
overdrawhigh = 100
overdrawlow = 100
cuthigh = 0
cutlow = 0
zoomin = 1
zoomout = .65
tensionhigh = 350
tensionlow = 200
;--------------------------------------------------------
[PlayerInfo]
;--- Player 1 ---
p1startx = -500      
p1starty = 0            ;
p1facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 2 ---
p2startx = 500
p2starty = 0
p2facing = -1

;--- Player 3 ---
p3startx = -720          ;Starting x coordinates
p3starty = 0            ;Starting y coordinates
p3facing = 1            ;Direction player faces: 1=right, -1=left

;--- Player 4 ---
p4startx = 720
p4starty = 0
p4facing = -1

;--- Common ---
 ;Don't change these values.


leftbound  = -1800
rightbound =  1800


;leftbound  = -3000
;rightbound =  3000
;--------------------------------------------------------
[Bound]
 ;Distance from left/right edge of screen that player can move to
 ;Typically 15
screenleft = 60;Dist from left of screen that player can move to
screenright = 60  ;Right edge
; use 15 for low res
; use 30 for high res
; use 60 for HD res
;--------------------------------------------------------
[StageInfo]
 ;"Ground" level where players stand at, measured in pixels from the
 ;top of the screen.
 ;Adjust this value to move the ground level up/down in the screen.
 ;***
zoffset = 650


 ;Leave this at 1. It makes the players face each other
autoturn = 1

 ;Set the following to 1 to have the background reset itself between
 ;rounds.
resetBG = 0
localcoord = 1280, 720


 ;Horizontal and vertical scaling factor for drawing.
xscale = 1
yscale = 1
;--------------------------------------------------------
[Shadow]
intensity = 100
color = 0,0,0
yscale = 0.15
fade.range = -400, -100






;--------------------------------------------------------
[Reflection]
intensity = 0


;--------------------------------------------------------
[Music]
bgmusic=sound/UchihaHideout.mp3
bgmvolume = 275


; Main background definition

;Action code tutorial by vogel
;[Begin Action 1]
sprite |Placement x,y |Flip (H for horizontal/ V for vertical) |Transparency 0-256 |Size (1 default)|angle for rotating animation 0-360 ( the plus sign in fighter factory is the axle! move the sprite with "start=" )
;0,0,  |0,0,0           |,H or V                                 |,0,0               |,1,1            |,0


;____________________________________________________________________________________________________________________________________
[BGdef]
spr = Uchiha Hideout Light.sff
debugbg = 1

[BG 0,ground gbs]
type = normal
spriteno = 0,3
start = 0,0
delta = 0.45,0.008
mask = 1
Tile = 1
xscale = 1,3
scaledelta = 0, -0.2
scalestart = 1,1


[BG 0,wall]
type = normal
spriteno = 0,2
tile = 1
start = 0,0
delta = 0.45,0.9
mask = 1
scalestart = 1,1

[BG 0,wall]
type = normal
spriteno = 0,1
start = 0,0
delta = 0.45,0.9
mask = 1
scalestart = 1,1

[BG 0,ground 1]
type = parallax
spriteno = 0,0
start = 0,0
delta = 0.45,0.008
mask = 1
Tile = 1
xscale = 1,3
scaledelta = 0, -0.2
scalestart = 1,1

[BG 0,ground light]
type = normal
spriteno = 1,0
start = 0,0
delta = 0.45,0.008
xscale = 1,3
scaledelta = 0, -0.2
trans = addalpha
alpha = 150, 255
scalestart = 1,1

[BG 0,chair back]
type = normal
spriteno = 2,3
start = 0,0
delta = 0.56,0.9
mask = 1
scalestart = 1,1

[BG 0,arm sides inside]
type = normal
spriteno = 2,4
start = 0,0
delta = 0.56,0.9
mask = 1
scalestart = 1,1

[BG 0,arms]
type = parallax
spriteno = 2,5
start = 0,0
delta = 0.56,0.9
xscale = 1,1.07142857143
mask = 1
scalestart = 1,1


[BG 0,chair seat]
type = parallax
spriteno = 2,2
start = 0,0
delta = 0.56,0.9
xscale = 1,1.04347826087
mask = 1
scalestart = 1,1

[BG 0,chair front]
type = normal
spriteno = 2,1
start = 0,0
delta = 0.583,0.9
mask = 1
scalestart = 1,1

[BG 0,chair arms front]
type = normal
spriteno = 2,0
start = 0,0
delta = 0.6,0.9
mask = 1
scalestart = 1,1


[BG 0,lightray 4]
type = normal
spriteno = 1,2
start = 0,0
delta = 0.6,0.9
mask = 1
Tile = 1
trans = addalpha
alpha = 150, 255
scalestart = 1,1

[BG 0,lightray 3]
type = normal
spriteno = 1,4
start = 0,0
delta = 0.6,0.9
mask = 1
Tile = 1
trans = addalpha
alpha = 150, 255
scalestart = 1,1

[BG 0,lightray 1]
type = normal
spriteno = 1,1
start = 0,0
delta = 1.1,1.2
mask = 1
Tile = 1
trans = addalpha
alpha = 150, 255
scalestart = 1,1
layerno = 1

[BG 0,lightray 2]
type = normal
spriteno = 1,3
start = 0,0
delta = 1.1,1.2
mask = 1
Tile = 1
trans = addalpha
alpha = 150, 255
scalestart = 1,1
layerno = 1


[Begin Action 1]
1,0, 0,0, 10, , AS156D256
