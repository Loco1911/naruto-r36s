[WinIcon]
p1.pos 			= 107,12
p2.pos 			= 212,12
; Offset for next icon (x,y)
p1.iconoffset 		= -6,0  
p2.iconoffset 		= 6,0
; Counter text font and offset for representing wins
p1.counter.offset 	= 25,25
p1.counter.font 	= 3,1
p2.counter.offset 	= -10,25
p2.counter.font 	= 3,-1

; Win by normal
p1.n.spr 		= 12,0
p1.n.scale 		= .5,.5
p2.n.spr 		= 12,0
p2.n.scale 		= -.5,.5

; Win by special
p1.s.spr 		= 12,1
p1.s.scale 		= .5,.5
p2.s.spr 		= 12,1
p2.s.scale 		= -.5,.5

; Win by hyper (super)
p1.h.spr 		= 12,2
p1.h.scale 		= .5,.5
p2.h.spr 		= 12,2
p2.h.scale 		= -.5,.5

; Win by normal throw
p1.throw.spr 		= 12,0
p1.throw.scale 		= .5,.5
p2.throw.spr 		= 12,0
p2.throw.scale 		= -.5,.5

; Win by cheese
p1.c.spr 		= 12,2
p1.c.scale 		= .5,.5
p2.c.spr 		= 12,2
p2.c.scale 		= -.5,.5

; Win by time over
p1.t.spr 		= 12,0
p1.t.scale 		= .5,.5
p2.t.spr 		= 12,0
p2.t.scale 		= -.5,.5

; Win by suicide (here's a fun one)
p1.suicide.spr 		= 12,0
p1.suicide.scale 	= .5,.5
p2.suicide.spr 		= 12,0
p2.suicide.scale 	= -.5,.5

; Opponent beaten by his own teammate (another fun one)
p1.teammate.spr 	= 12,0
p1.teammate.scale 	= .5,.5
p2.teammate.spr 	= 12,0
p2.teammate.scale 	= -.5,.5

; Win by perfect (overlay icon)
p1.perfect.spr 		= ;110,0
p2.perfect.spr 		= ;110,0

; Use icons up until this number of wins
useiconupto 		= 4

