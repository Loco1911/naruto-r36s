[Time]
pos = 159,19
; Uncomment the following line to use a bg component
;bg.spr = 
; Time count display
counter.offset = 0,0
counter.font = 3,0, 0
counter.layerno = 2
; Ticks for each count
framespercount = 60

;-----------------------------------------------------------
[Combo]
pos = 26,80         ;Coords to show
start.x = -120      ;Starting x-coords
counter.font = 4,0, 0
text.text = 0
text.font = 5,0, 0
text.offset = -26,6   ;Offset of text
displaytime = 90    ;Time to show text

;-----------------------------------------------------------
[Round]
match.wins = 2              ;Rounds needed to win a match
match.maxdrawgames = 1      ;Max number of drawgames allowed (-1 for infinite) *2001.11.01 NEW*
start.waittime = 30         ;Time to wait before starting intro

; Default position for all components
pos = 0,0

; ROUND X
round.time = 0              ;Time to show round display
round.default.offset = 65, 105
; Default component to show for each round. Text can include a %i to
; the round number. Use "round.default.anim" for animation instead of
; text.
round.default.anim = 41
round.default.displaytime = 70
; Sounds to play for each round (optional, specify up to round 9)
round1.snd = 0,0
round2.snd = 0,1
round3.snd = 0,2
round4.snd = 0,3
round5.snd = 0,4
round.sndtime = 0           ;Time to play the sounds
; Components to show for each round (optional, specify up to round 9)
; Uncomment to use
round1.offset = 221, 88
round1.anim = 51
round2.offset = 221, 88
round2.anim = 52
round3.offset = 221, 88
round3.anim = 53
round4.offset = 221, 88
round4.anim = 54
round5.offset = 221, 88
round5.anim = 55
round6.offset = 221, 88
round6.anim = 56
round7.offset = 221, 88
round7.anim = 57
round8.offset = 221, 88
round8.anim = 58
round9.offset = 221, 88
round9.anim = 59

; FIGHT
fight.time = 0              ;Time to show FIGHT component
fight.offset = 65, 105      ;Component for FIGHT display
fight.anim = 45
fight.snd = 1,0             ;Sound to play
fight.sndtime = 0           ;Time to play sound

ctrl.time = 159             ;Time players get control after "Fight"

; KO
KO.time    = 0              ;Time to show KO component
KO.offset  = 93, 92         ;Component for KO display
KO.anim    = 60
KO.displaytime = 90
KO.snd     = 2,1            ;Sound to play for KO announcement
; Double KO
DKO.offset = 93, 92
DKO.anim    = 60
DKO.displaytime = 90
DKO.snd    = 2,1
; Time Over
TO.offset  = 93, 92
TO.anim    = 60
TO.displaytime = 90
TO.snd     = 2,1
KO.sndtime = 0             ;Time to play sound for KO, DKO and TO.
slow.time  = 60            ;Time for KO slowdown (in ticks)
over.waittime = 45         ;Time to wait after KO before player control is stopped
over.hittime = 10          ;Time after KO that players can still damage each other (for double KO)
over.wintime = 45          ;Time to wait before players change to win states
over.time = 360            ;Time to wait before round ends
; Time to wait before showing win/draw message
win.time = 60
; Win text
win.offset = 160, 70
win.font = 1,0
win.text = ;%s Wins
win.displaytime = 540
; 2-player win text
win2.offset = 160, 70
win2.font = 1,0
win2.text = ;%s and %s Win
win2.displaytime = 540
; Draw text
draw.offset = 160, 70
draw.font = 1,0
draw.text = Draw Game
draw.displaytime = 540

