[WinIcon]
p1.pos = 131,33
p2.pos = 182,33
; Offset for next icon (x,y)
p1.iconoffset = -8,0
p2.iconoffset = 8,0
; Win by normal
p1.n.spr = 21,0
p1.n.layerno = 2
p2.n.spr = 21,0
p2.n.layerno = 2
; Win by special
p1.s.spr = 21,0
p1.s.layerno = 2
p2.s.spr = 21,0
p2.s.layerno = 2
; Win by hyper (super)
p1.h.spr = 21,0
p1.h.layerno = 2
p2.h.spr = 21,0
p2.h.layerno = 2
; Win by normal throw
p1.throw.spr = 21,0
p2.throw.spr = 21,0
; Win by cheese
p1.c.spr = 21,0
p1.c.layerno = 2
p2.c.spr = 21,0
p2.c.layerno = 2
; Win by time over
p1.t.spr = 21,0
p1.t.layerno = 2
p2.t.spr = 21,0
p2.t.layerno = 2
; Win by suicide (here's a fun one)
p1.suicide.spr = 21,0
p1.suicide.layerno = 2
p2.suicide.spr = 21,0
p2.suicide.layerno = 2
; Opponent beaten by his own teammate (another fun one)
p1.teammate.spr = 21,0
p1.teammate.layerno = 2
p2.teammate.spr = 21,0
p2.teammate.layerno = 2
; Win by perfect (overlay icon)
p1.perfect.spr = 21,0
p1.perfect.layerno = 2
p2.perfect.spr = 21,0
p2.perfect.layerno = 2
; Use icons up until this number of wins
useiconupto = 4
