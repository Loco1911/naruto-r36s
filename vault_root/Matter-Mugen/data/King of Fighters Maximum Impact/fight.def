[WinIcon]
p1.pos = 20,49   ;33,43
p2.pos = 302,49   ;286,43
; Offset for next icon (x,y)
p1.iconoffset = 16,0  
p2.iconoffset = -16,0
; Counter text font and offset for representing wins
;p1.counter.offset = 0,0
;p1.counter.font = 2,1
;p2.counter.offset = 0,0
;p2.counter.font = 2,1
; Win by normal
p1.n.anim = 100
p2.n.anim = 100
; Win by special
p1.s.anim = 100
p2.s.anim = 100
; Win by hyper (super)
p1.h.anim = 100
p2.h.anim = 100
; Win by normal throw
p1.throw.anim = 100
p2.throw.anim = 100
; Win by cheese
p1.c.anim = 100
p2.c.anim = 100
; Win by time over
p1.t.anim = 100
p2.t.anim = 100
; Win by suicide (here's a fun one)
p1.suicide.anim = 100
p2.suicide.anim = 100
; Opponent beaten by his own teammate (another fun one)
p1.teammate.anim = 100
p2.teammate.anim = 100
; Win by perfect (overlay icon)
p1.perfect.anim = 100
p2.perfect.anim = 100
; Use icons up until this number of wins
useiconupto = 2

[Begin Action 100]
100,0, 0,0, -1
