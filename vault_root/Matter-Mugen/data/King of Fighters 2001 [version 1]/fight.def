[Lifebar] ;싱글이나 VS 플레이일 경우에만 해당
;Player 1
p1.pos    = 143,15 ;1P에너지 바 스프라이트 위치
p1.bg0.spr = 100,1
p1.bg0.offset = 0,-1
p1.bg1.spr = 11,0 ;1P의 에너지가 0 상태인 에너지바 스프라이트 번호
