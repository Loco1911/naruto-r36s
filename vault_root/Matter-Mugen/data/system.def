;----------------------------

[Info]
name =KOF_Mugen DataBase;Name of motif
author =Matter;Motif author name

;----------------------------

[Files]
spr =system.sff;Filename of sprite data
snd =system.snd;Filename of sound data
logo.storyboard =Load.def
intro.storyboard =intro.def;Intro storyboard definition (optional)
select =select.def;Character and stage selection list
fight =data/KOFMLV2/fight.def
font1 =font/Small FontsM.fnt;System fonts
font2 =font/Small FontsM.fnt;System fonts
font3 =font/Max1.fnt
font4 =font/hl3charwin.fnt
;----------------------------
[Music]
title.bgm =sound/Menu-1.mp3
title.bgm.loop = 1
select.bgm =data/End-Bad.mp3
select.bgm.loop = 1
vs.bgm =data/NvsM.ogg
vs.bgm.loop = 0

;-------------------------------------------------------------------
;Title screen definition
[Title Info]
fadein.time =90
fadeout.time =60
menu.pos =160,98
menu.item.font =3,0,0
menu.item.active.font =3,0,0
menu.item.spacing =0, 23
; Names for each of the items in the menu. Names must be in quotes.
; Use "" to disable an item. If all are disabled, goes straight to demo mode
; (hold Esc to quit demos). *2001.11.14 NEW*
menu.itemname.arcade ="Arcade"
menu.itemname.versus ="Versus"
menu.itemname.teamarcade ="Team Arcade"
menu.itemname.teamversus ="Team Versus"
menu.itemname.teamcoop ="Team Co-Op"
menu.itemname.survival ="Survival"
menu.itemname.survivalcoop ="Survival Co-Op"
menu.itemname.training ="Training"
menu.itemname.watch ="Watch"
menu.itemname.options ="Options"
menu.itemname.exit ="Exit"
; These parameters define the window in which the items are visible
; in.
menu.window.margins.y =12, 8
menu.window.visibleitems =1
menu.boxcursor.visible =0;Set to 0 to disable default cursor display
menu.boxcursor.coords =-58,-10,57,2
; These are the sounds for cursor movement
cursor.move.snd = 0,0
cursor.done.snd = 0,2
cancel.snd = 0,3

