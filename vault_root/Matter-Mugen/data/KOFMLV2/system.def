;----------------------------
[Info]
name ="The King Of Fighters Memorial ver 31.0"
author ="zelgadis"
;versiondate = 03/03/2010
;mugenversion = 1.0
;localcoord = 320,240
;Adapted to winmugen by Act52
;----------------------------
[Files]
spr = system.sff
snd = system.snd
logo.storyboard = Loading.def
intro.storyboard = Little.def
select = select.def
fight  = fight.def
font1  = font/f-4x6.fnt
font2  = font/Menu-Small.fnt
font3  = font/Menu-Medium.fnt
font4  = font/Menu-Big.fnt
font5  = font/Names.fnt
font6  = font/Names1.fnt
;----------------------------
[Music]
title.bgm = sound/Title.ogg 
;title.bgm.volume = 150
title.bgm.loop = 1
;title.bgm.loopstart = 
;title.bgm.loopend = 
  ;Music to play at char select screen.
select.bgm = sound/Select.ogg 
;select.bgm.volume = 150
select.bgm.loop = 1
;select.bgm.loopstart =
;select.bgm.loopend = 
  ;Music to play at versus screen.
vs.bgm = sound/Versus.ogg 
;vs.bgm.volume = 150
vs.bgm.loop = 0
;vs.bgm.loopstart =
;vs.bgm.loopend = 
;-------------------------------------------------------------------
;Title screen definition
[Title Info]
fadein.time = 15
fadeout.time = 15
menu.window.visibleitems = 11
menu.window.margins.y = 9,8
menu.window.visibleitems = 5
menu.boxcursor.visible = 1
menu.boxcursor.coords = -60,-9,60,0
menu.pos = 250,140
menu.item.font = 5
menu.item.active.font = 6
menu.item.spacing = 0,9
menu.itemname.arcade = ""
menu.itemname.versus = ""
menu.itemname.teamarcade = "Team Play"
menu.itemname.teamversus = "Team Challenge"
menu.itemname.teamcoop = "Team Co-op"
menu.itemname.survival = "Endless Play"
menu.itemname.survivalcoop = "Endless Co-op"
menu.itemname.training = "Practice"
menu.itemname.watch = "Watch"
menu.itemname.options = "Game Options"
menu.itemname.exit = "Exit"
cursor.move.snd = 100,0
cursor.done.snd = 100,1
cancel.snd = 100,2
