
[SceneDef]
spr = credits.sff
startscene = 0 

;------------------------------------
[Scene 0]
; Fade
fadein.time = 100
fadein.col = 0,0,0
fadeout.time = 100
fadeout.col = 0,0,0
; Screen color
clearcolor = 0,0,0

bg.name = BG0
layerall.pos = 0,0
layer0.anim =  10
layer0.offset = 0,0
layer0.starttime = 100

layer1.anim =  1  
layer1.offset = 0,0
layer1.starttime = 3695

layer2.anim =  0 
layer2.offset = 0,0
layer2.starttime = 300

; Music
bgm = Credits.ogg
bgm.loop = 0
; Total time
end.time = 18000

;------------------------------------
;BG def for scrolling credit text
[BG0Def]

[BG0 Credits]
id = 1
type = normal
spriteno = 0,0
start = 0,0
tile = 1,1
tilespacing = 0,0

;BG controller to stop text from scrolling
[BG0CtrlDef Credits]
CtrlID = 1
looptime = -1

[BG0Ctrl Start scrolling]
type = VelSet
time = 0
x = -12

