[Files]
sff         = fight.sff	     ; archivo de imagenes
snd         = fight.snd       ; archivo de sonido

font1       = font/kof2k2_hit.fnt         ; combo	
font2       = font/kof2k2_tiempo.fnt      ; tiempo   
font3       = font/kof2k2_poder1.fnt      ; poder peleador numero 1   
font4 	    = font/kof2k2_poder2.fnt      ; poder peleador numero 2	
font5       = font/kof2k2_verde.fnt       ; nombre - letras en verde  
font6       = font/kof2k2_amarillo.fnt    ; nombre - letras en amarillo 
font7       = font/kof2k2_gris.fnt        ; nombre - letras en gris 
font8       = font/kof2k2_victorias01.fnt ; victorias - letras en rojo
font9       = font/kof2k2_victorias02.fnt ; victorias - letras en azul

fightfx.sff = fightfx.sff            ; archivo de efectos
fightfx.air = fightfx.air            ; archivo de declaracion

common.snd  = common.snd

